###> azure/translator ###
# IMPORTANT: Put real secrets in .env.local (never commit them).
# Endpoint for TEXT translation API (v3): https://api.cognitive.microsofttranslator.com/
AZURE_TRANSLATOR_ENDPOINT="https://api.cognitive.microsofttranslator.com/"
AZURE_TRANSLATOR_REGION="francecentral"

# Secrets (set in .env.local):
AZURE_TRANSLATOR_KEY_PRIMARY=""
AZURE_TRANSLATOR_KEY_SECONDARY=""

# Cache (seconds). Example: 30 days.
AZURE_TRANSLATOR_CACHE_TTL_SECONDS=2592000
###< azure/translator ###

###> gemini/chatbot ###
# Google Gemini API Configuration
# Endpoint for Gemini Flash 2.5 API
GEMINI_API_ENDPOINT="https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent"
# Model name
GEMINI_MODEL_NAME="gemini-2.5-flash"
# Timeout for API calls (milliseconds)
GEMINI_API_TIMEOUT=30000
# API Key (set in .env.local - NEVER commit this)
GEMINI_API_KEY=""
# Enable chatbot feature
GEMINI_CHATBOT_ENABLED=true
###< gemini/chatbot ###

