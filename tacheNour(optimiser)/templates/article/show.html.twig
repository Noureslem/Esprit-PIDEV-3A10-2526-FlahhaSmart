{% extends 'articleview.html.twig' %}

{% block title %}{{ article.nom }} - FlahaSmart Admin{% endblock %}

{% block body %}
<div class="container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_article_index') }}">Articles</a></li>
            <li class="breadcrumb-item active">{{ article.nom }}</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-5">
            {% if article.imageUrl %}
                <img src="{{ article.imageUrl }}" class="img-fluid rounded shadow" alt="{{ article.nom }}">
            {% else %}
                <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height: 300px;">
                    🌿 <span class="text-muted">Image non disponible</span>
                </div>
            {% endif %}
        </div>
        <div class="col-md-7">
            <h1>{{ article.nom }}</h1>
            <p class="lead">{{ article.description }}</p>
            <hr>
            <div class="row mb-3">
                <div class="col-6">
                    <strong>💰 Prix :</strong> {{ article.prix }} €
                </div>
                <div class="col-6">
                    <strong>📦 Stock :</strong> {{ article.stock }} unités
                </div>
                <div class="col-6 mt-2">
                    <strong>🏷️ Catégorie :</strong> {{ article.categorie }}
                </div>
                <div class="col-6 mt-2">
                    <strong>⚖️ Poids :</strong> {{ article.poids ?? 'Non spécifié' }} {{ article.unite ?? 'kg' }}
                </div>
                <div class="col-6 mt-2">
                    <strong>📅 Date d'ajout :</strong> {{ article.dateAjout|date('d/m/Y') }}
                </div>
                <div class="col-6 mt-2">
                    <strong>👤 ID utilisateur :</strong> {{ article.idUser ?? 'Public' }}
                </div>
            </div>
            <hr>
            <div class="d-flex gap-2">
                <a href="{{ path('app_article_edit', {id: article.id}) }}" class="btn btn-warning">✏️ Modifier</a>
                <a href="{{ path('app_article_index') }}" class="btn btn-secondary">← Retour</a>
            </div>
        </div>
    </div>

    <!-- QR Code section (admin) -->
    <div class="row mt-5">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-white">
                    <strong>📱 QR Code de l'article (public)</strong>
                </div>
                <div class="card-body text-center">
                    {% if article.qrCodeFilename %}
                        <img src="{{ asset('uploads/qrcodes/' ~ article.qrCodeFilename) }}" alt="QR Code" style="width: 200px;">
                        <p class="mt-2">Scannez ce code pour accéder à la page publique de l'article.</p>
                    {% else %}
                        <p class="text-muted">Aucun QR code généré pour cet article.</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
