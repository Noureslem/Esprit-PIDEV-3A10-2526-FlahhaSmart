{% extends 'base.html.twig' %}

{% block body %}
    <div class="max-w-2xl mx-auto bg-white rounded-xl shadow-md p-6">
        <h1 class="text-2xl font-bold text-gray-800 mb-6">✏️ Modifier le commentaire</h1>
        <form method="post" novalidate>
            <textarea name="contenu" rows="4" class="w-full border-gray-300 rounded-lg mb-4">{{ commentaire.contenu }}</textarea>
            <div class="flex justify-end space-x-2">
                <a href="{{ path('thread_show', {id: commentaire.idThread}) }}" class="px-4 py-2 bg-gray-200 rounded-lg">Annuler</a>
                <button type="submit" class="px-4 py-2 bg-green-600 text-white rounded-lg">Enregistrer</button>
            </div>
        </form>
    </div>
{% endblock %}