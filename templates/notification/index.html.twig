{% extends 'base.html.twig' %}

{% block body %}
    <div class="max-w-2xl mx-auto bg-white rounded-xl shadow-md p-6">
        <h1 class="text-2xl font-bold mb-6">🔔 Notifications</h1>

        {% if notifications is empty %}
            <p class="text-gray-500">Aucune notification pour l'instant.</p>
        {% else %}
            <div class="space-y-3">
                {% for notif in notifications %}
                    <div class="border-b border-gray-100 py-3 flex justify-between items-start">
                        <div>
                            <p class="text-gray-800">{{ notif.message }}</p>
                            <span class="text-xs text-gray-400">{{ notif.dateNotif|date('d/m/Y H:i') }}</span>
                        </div>
                        {% if not notif.lu %}
                            <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded-full">Nouveau</span>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}