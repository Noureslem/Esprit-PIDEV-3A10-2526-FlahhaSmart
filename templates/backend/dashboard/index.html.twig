{% extends 'base.html.twig' %}

{% block title %}{{ 'dashboard.index.title'|trans }}{% endblock %}
{% block navbar_title %}{{ 'dashboard.index.navbar_title'|trans }}{% endblock %}

{% block body %}
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="page-title">
                <i class="bi bi-bar-chart me-2"></i>{{ 'dashboard.index.title'|trans }}
            </h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="#">{{ 'common.home'|trans }}</a></li>
                    <li class="breadcrumb-item active">{{ 'nav.dashboard'|trans }}</li>
                </ol>
            </nav>
        </div>
        <button class="btn btn-outline-success" id="refreshBtn">
            <i class="bi bi-arrow-clockwise me-1"></i>{{ 'dashboard.actions.refresh'|trans }}
        </button>
    </div>

    <!-- KPI Cards -->
    <div class="row g-3 mb-4">
        <!-- Operations Section -->
        <div class="col-md-3">
            <div class="kpi-card">
                <div class="kpi-header">
                    <i class="bi bi-lightning-fill"></i>
                </div>
                <div class="kpi-body">
                    <h6 class="kpi-label">{{ 'dashboard.kpi.operations_total'|trans }}</h6>
                    <h2 class="kpi-value" id="totalOperations">{{ operationsSummary.total }}</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="kpi-card">
                <div class="kpi-header" style="background: linear-gradient(135deg, #fbbf24, #f59e0b);">
                    <i class="bi bi-hourglass-split"></i>
                </div>
                <div class="kpi-body">
                    <h6 class="kpi-label">{{ 'dashboard.kpi.operations_in_progress'|trans }}</h6>
                    <h2 class="kpi-value" id="inProgressOperations">{{ operationsSummary.inProgress }}</h2>
                    <small class="kpi-subtitle">{{ operationsSummary.inProgress > 0 ? (operationsSummary.inProgress / operationsSummary.total * 100)|round(1) : 0 }}%</small>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="kpi-card">
                <div class="kpi-header" style="background: linear-gradient(135deg, #34d399, #10b981);">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <div class="kpi-body">
                    <h6 class="kpi-label">{{ 'dashboard.kpi.operations_completed'|trans }}</h6>
                    <h2 class="kpi-value" id="completedOperations">{{ operationsSummary.completed }}</h2>
                    <small class="kpi-subtitle">{{ 'dashboard.kpi.completion_rate'|trans({'%rate%': operationsSummary.completionRate}) }}</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="row g-3">
        <!-- Equipment by Type -->
        <div class="col-lg-6">
            <div class="chart-card">
                <div class="chart-header">
                    <h5 class="mb-0">
                        <i class="bi bi-pie-chart-fill me-2"></i>{{ 'dashboard.charts.equipment_by_type'|trans }}
                    </h5>
                </div>
                <div class="chart-body">
                    <div id="equipmentTypeChartContainer" style="height: 300px; position: relative;">
                        <canvas id="equipmentTypeChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Equipment Usage -->
        <div class="col-lg-6">
            <div class="chart-card">
                <div class="chart-header">
                    <h5 class="mb-0">
                        <i class="bi bi-diagram-3-fill me-2"></i>{{ 'dashboard.charts.equipment_usage'|trans }}
                    </h5>
                </div>
                <div class="chart-body">
                    <div id="equipmentUsageChartContainer" style="height: 300px; position: relative;">
                        <canvas id="equipmentUsageChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Upcoming Operations Section -->
    <div class="row mt-5 mb-4">
        <div class="col-12">
            <h4 class="mb-4">
                <i class="bi bi-calendar-event me-2"></i>{{ 'dashboard.upcoming.title'|trans }}
            </h4>
            <div class="upcoming-operations-table">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th scope="col">{{ 'dashboard.upcoming.table.operation'|trans }}</th>
                                <th scope="col">{{ 'dashboard.upcoming.table.equipment'|trans }}</th>
                                <th scope="col">{{ 'dashboard.upcoming.table.end_date'|trans }}</th>
                                <th scope="col">{{ 'dashboard.upcoming.table.days_remaining'|trans }}</th>
                                <th scope="col">{{ 'dashboard.upcoming.table.status'|trans }}</th>
                                <th scope="col" class="text-end">{{ 'dashboard.upcoming.table.action'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody id="upcomingOperationsBody">
                            {% if upcomingOperations|length > 0 %}
                                {% for op in upcomingOperations %}
                                    <tr class="operation-row" data-operation-id="{{ op.id }}">
                                        <td>
                                            <strong>{{ op.typeOperation }}</strong>
                                        </td>
                                        <td>
                                            <i class="bi bi-box-seam me-1"></i>
                                            {{ op.equipement }}
                                        </td>
                                        <td>
                                            <i class="bi bi-calendar me-1"></i>
                                            {{ op.dateFin }}
                                        </td>
                                        <td>
                                            <span class="badge {% if op.daysRemaining <= 1 %}bg-danger{% elseif op.daysRemaining <= 7 %}bg-warning text-dark{% else %}bg-success{% endif %}">
                                                {{ op.daysRemaining }} {{ (op.daysRemaining > 1 ? 'common.day_plural' : 'common.day_singular')|trans }}
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge badge-status-{{ op.statusClass }}">
                                                {{ op.statut }}
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            {% if op.statut|lower != 'terminé' %}
                                                <button class="btn btn-sm btn-outline-success terminate-btn" 
                                                        data-operation-id="{{ op.id }}"
                                                        title="{{ 'dashboard.upcoming.actions.terminate_tooltip'|trans }}">
                                                    <i class="bi bi-check-circle me-1"></i>{{ 'operation.actions.finish'|trans }}
                                                </button>
                                            {% else %}
                                                <span class="text-muted small">{{ 'common.completed'|trans }}</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% else %}
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">
                                        {{ 'dashboard.upcoming.empty'|trans }}
                                    </td>
                                </tr>
                            {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Last Updated -->
    <div class="row mt-4">
        <div class="col-12">
            <small class="text-muted" id="lastUpdated">
                {{ 'dashboard.last_updated'|trans }}: <span id="updateTime">{{ "now"|date('H:i:s') }}</span>
            </small>
        </div>
    </div>

    {# Chart.js Library #}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.js"></script>

    <script>
        const i18n = {
            confirmTerminate: {{ 'dashboard.confirm.terminate'|trans|json_encode|raw }},
            terminating: {{ 'dashboard.actions.terminating'|trans|json_encode|raw }},
            terminate: {{ 'operation.actions.finish'|trans|json_encode|raw }},
            terminateTooltip: {{ 'dashboard.upcoming.actions.terminate_tooltip'|trans|json_encode|raw }},
            completed: {{ 'common.completed'|trans|json_encode|raw }},
            terminated: {{ 'common.terminated'|trans|json_encode|raw }},
            refreshInProgress: {{ 'dashboard.actions.refreshing'|trans|json_encode|raw }},
            statsUpdated: {{ 'dashboard.notifications.stats_updated'|trans|json_encode|raw }},
            operationTerminated: {{ 'dashboard.notifications.operation_terminated'|trans|json_encode|raw }},
            terminationError: {{ 'dashboard.errors.termination'|trans|json_encode|raw }},
            updateError: {{ 'dashboard.errors.update'|trans|json_encode|raw }},
            noUpcoming: {{ 'dashboard.upcoming.empty'|trans|json_encode|raw }},
            daySingular: {{ 'common.day_singular'|trans|json_encode|raw }},
            dayPlural: {{ 'common.day_plural'|trans|json_encode|raw }},
            equipmentStateAvailable: {{ 'equipement.state.available'|trans|json_encode|raw }},
            equipmentStateReserved: {{ 'equipement.state.reserved'|trans|json_encode|raw }},
        };

        // Chart instances
        let equipmentTypeChart = null;
        let equipmentUsageChart = null;

        // Color palette
        const colors = {
            primary: '#10b981',
            secondary: '#34d399',
            success: '#10b981',
            warning: '#f59e0b',
            danger: '#ef4444',
            info: '#3b82f6',
            light: '#f3f4f6',
            dark: '#1f2937',
        };

        // Initialize charts on page load
        document.addEventListener('DOMContentLoaded', function() {
            initCharts();
            setupRefreshButton();
            setupTerminateButtons();
        });

        /**
         * Initialize all charts
         */
        function initCharts() {
            const statisticsData = {
                equipmentByType: {{ statistics.equipementByType|json_encode|raw }},
                equipmentUsage: {{ equipementUsageData|json_encode|raw }},
            };

            initEquipmentTypeChart(statisticsData.equipmentByType);
            initEquipmentUsageChart(statisticsData.equipmentUsage);
        }

        /**
         * Initialize Equipment by Type Pie Chart
         */
        function initEquipmentTypeChart(data) {
            const ctx = document.getElementById('equipmentTypeChart');
            if (!ctx) return;
            
            const chartCtx = ctx.getContext('2d');
            
            if (equipmentTypeChart) {
                equipmentTypeChart.destroy();
            }

            // Validate and prepare data
            const labels = (data && data.labels) ? data.labels : [];
            const chartData = (data && data.data && Array.isArray(data.data)) ? data.data : [];
            const backgroundColor = (data && data.backgroundColor) ? data.backgroundColor : [colors.primary];

            equipmentTypeChart = new Chart(chartCtx, {
                type: 'pie',
                data: {
                    labels: labels,
                    datasets: [{
                        data: chartData,
                        backgroundColor: backgroundColor,
                        borderColor: '#ffffff',
                        borderWidth: 2,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 15,
                                font: {
                                    size: 14,
                                    weight: '500',
                                },
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    const percentage = total > 0 ? Math.round((context.parsed / total) * 100) : 0;
                                    return context.label + ': ' + context.parsed + ' (' + percentage + '%)';
                                }
                            }
                        }
                    },
                    animation: {
                        animateRotate: true,
                        animateScale: false,
                        duration: 1000,
                    }
                }
            });
        }

        /**
         * Initialize Equipment Usage Donut Chart
         */
        function initEquipmentUsageChart(data) {
            const ctx = document.getElementById('equipmentUsageChart');
            if (!ctx) return;
            
            const chartCtx = ctx.getContext('2d');
            
            if (equipmentUsageChart) {
                equipmentUsageChart.destroy();
            }

            // Validate and prepare data
            const labels = (data && data.labels) ? data.labels : [i18n.equipmentStateAvailable, i18n.equipmentStateReserved];
            const chartData = (data && data.data && Array.isArray(data.data)) ? data.data : [0, 0];
            const backgroundColor = (data && data.backgroundColor) ? data.backgroundColor : ['#10b981', '#ef4444'];

            equipmentUsageChart = new Chart(chartCtx, {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        data: chartData,
                        backgroundColor: backgroundColor,
                        borderColor: '#ffffff',
                        borderWidth: 3,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 15,
                                font: {
                                    size: 14,
                                    weight: '500',
                                },
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    const percentage = total > 0 ? Math.round((context.parsed / total) * 100) : 0;
                                    return context.label + ': ' + context.parsed + ' (' + percentage + '%)';
                                }
                            }
                        }
                    },
                    animation: {
                        animateRotate: true,
                        animateScale: false,
                        duration: 1000,
                    }
                }
            });
        }

        /**
         * Setup refresh button
         */
        function setupRefreshButton() {
            const refreshBtn = document.getElementById('refreshBtn');
            refreshBtn.addEventListener('click', refreshStatistics);
        }

        /**
         * Setup terminate buttons
         */
        function setupTerminateButtons() {
            document.querySelectorAll('.terminate-btn').forEach(btn => {
                btn.addEventListener('click', handleTerminateOperation);
            });
        }

        /**
         * Handle terminate operation via AJAX
         */
        function handleTerminateOperation(e) {
            e.preventDefault();
            const btn = e.target.closest('.terminate-btn');
            const operationId = btn.dataset.operationId;
            const row = btn.closest('.operation-row');

            const doTerminate = () => {
                btn.disabled = true;
                btn.innerHTML = `<i class="bi bi-hourglass-split me-1"></i>${i18n.terminating}`;

                const url = `/dashboard/api/operations/${operationId}/terminate`;

                fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Update row status
                        const statusCell = row.querySelector('td:nth-child(5)');
                        statusCell.innerHTML = `<span class="badge badge-status-termine">${i18n.terminated}</span>`;

                        // Replace button with "completed" text
                        const actionCell = row.querySelector('td:nth-child(6)');
                        actionCell.innerHTML = `<span class="text-muted small">${i18n.completed}</span>`;

                        showNotification(i18n.operationTerminated, 'success');

                        // Refresh statistics after 1 second
                        setTimeout(refreshStatistics, 1000);
                    } else {
                        showNotification(data.message || i18n.terminationError, 'error');
                        btn.disabled = false;
                        btn.innerHTML = `<i class="bi bi-check-circle me-1"></i>${i18n.terminate}`;
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    showNotification(i18n.terminationError, 'error');
                    btn.disabled = false;
                    btn.innerHTML = `<i class="bi bi-check-circle me-1"></i>${i18n.terminate}`;
                });
            };

            if (window.AppConfirmModal && typeof window.AppConfirmModal.confirm === 'function') {
                window.AppConfirmModal.confirm(i18n.confirmTerminate, doTerminate);
            } else {
                // Fallback if modal isn't available
                if (confirm(i18n.confirmTerminate)) {
                    doTerminate();
                }
            }
        }

        /**
         * Refresh statistics via AJAX
         */
        function refreshStatistics() {
            const btn = document.getElementById('refreshBtn');
            const originalContent = btn.innerHTML;
            
            btn.disabled = true;
            btn.innerHTML = `<i class="bi bi-hourglass-split me-1"></i>${i18n.refreshInProgress}`;

            fetch('{{ path("app_dashboard_api_statistics") }}')
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Erreur réseau: ' + response.status);
                    }
                    return response.json();
                })
                .then(data => {
                    if (data.success) {
                        console.log('Statistics updated:', data.data);
                        updateStatistics(data.data);
                        updateTimestamp();
                        showNotification(i18n.statsUpdated, 'success');
                    } else {
                        throw new Error('La réponse n\'a pas indiqué le succès');
                    }
                })
                .catch(error => {
                    console.error('Error updating statistics:', error);
                    showNotification(i18n.updateError, 'error');
                })
                .finally(() => {
                    btn.disabled = false;
                    btn.innerHTML = originalContent;
                });
        }

        /**
         * Update KPI cards with new data
         */
        function updateStatistics(data) {
            const ops = data.operations;
            const equip = data.equipement;
            const charts = data.charts;
            const upcomingOps = data.upcomingOperations;

            // Update operations KPIs
            document.getElementById('totalOperations').textContent = ops.total;
            document.getElementById('inProgressOperations').textContent = ops.inProgress;
            document.getElementById('completedOperations').textContent = ops.completed;

            // Update charts - ensure data structure is valid
            if (charts.equipementByType && charts.equipementByType.labels && charts.equipementByType.labels.length > 0) {
                initEquipmentTypeChart(charts.equipementByType);
            }
            
            if (charts.equipementUsage && charts.equipementUsage.labels && charts.equipementUsage.data) {
                initEquipmentUsageChart(charts.equipementUsage);
            }

            // Update upcoming operations if available
            if (upcomingOps && Array.isArray(upcomingOps)) {
                updateUpcomingOperations(upcomingOps);
            }
        }

        /**
         * Update upcoming operations table
         */
        function updateUpcomingOperations(operations) {
            const tbody = document.getElementById('upcomingOperationsBody');
            
            if (operations.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" class="text-center py-4 text-muted">${i18n.noUpcoming}</td></tr>`;
                return;
            }

            tbody.innerHTML = operations.map(op => `
                <tr class="operation-row" data-operation-id="${op.id}">
                    <td><strong>${op.typeOperation}</strong></td>
                    <td><i class="bi bi-box-seam me-1"></i>${op.equipement}</td>
                    <td><i class="bi bi-calendar me-1"></i>${op.dateFin}</td>
                    <td>
                        <span class="badge ${getDaysRemainingBadgeClass(op.daysRemaining)}">
                            ${op.daysRemaining} ${op.daysRemaining > 1 ? i18n.dayPlural : i18n.daySingular}
                        </span>
                    </td>
                    <td><span class="badge badge-status-${op.statusClass}">${op.statut}</span></td>
                    <td class="text-end">
                        ${op.statut.toLowerCase() !== 'terminé' ? 
                            `<button class="btn btn-sm btn-outline-success terminate-btn" data-operation-id="${op.id}" title="${i18n.terminateTooltip}">
                                <i class="bi bi-check-circle me-1"></i>${i18n.terminate}
                            </button>` : 
                            `<span class="text-muted small">${i18n.completed}</span>`
                        }
                    </td>
                </tr>
            `).join('');

            // Re-setup terminate buttons
            setupTerminateButtons();
        }

        /**
         * Get badge class based on days remaining
         */
        function getDaysRemainingBadgeClass(daysRemaining) {
            if (daysRemaining <= 1) return 'bg-danger';
            if (daysRemaining <= 7) return 'bg-warning text-dark';
            return 'bg-success';
        }

        /**
         * Update last update timestamp
         */
        function updateTimestamp() {
            const now = new Date();
            const timeString = now.getHours().toString().padStart(2, '0') + ':' +
                             now.getMinutes().toString().padStart(2, '0') + ':' +
                             now.getSeconds().toString().padStart(2, '0');
            document.getElementById('updateTime').textContent = timeString;
        }

        /**
         * Show notification (requires Bootstrap alerts)
         */
        function showNotification(message, type) {
            const bsType = type === 'error' ? 'danger' : type;
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${bsType} alert-dismissible fade show position-fixed top-0 end-0 m-3`;
            alertDiv.style.zIndex = '9999';
            alertDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.body.appendChild(alertDiv);

            setTimeout(() => {
                alertDiv.remove();
            }, 3000);
        }

        // Auto-refresh every 5 minutes
        setInterval(refreshStatistics, 5 * 60 * 1000);
    </script>

    <style>
        .kpi-card {
            background: linear-gradient(135deg, #10b981, #34d399);
            border-radius: 0.75rem;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
            animation: slideIn 0.5s ease-out;
        }

        .kpi-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 16px rgba(16, 185, 129, 0.2);
        }

        .kpi-header {
            background: linear-gradient(135deg, #10b981, #059669);
            padding: 1.5rem;
            color: #fff;
            font-size: 2rem;
            text-align: center;
        }

        .kpi-body {
            padding: 1.25rem;
            background: #fff;
            color: #1f2937;
        }

        .kpi-label {
            font-size: 0.875rem;
            color: #6b7280;
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-weight: 600;
        }

        .kpi-value {
            font-size: 2rem;
            font-weight: 700;
            color: #10b981;
            margin: 0.25rem 0;
        }

        .kpi-subtitle {
            color: #9ca3af;
            font-weight: 500;
        }

        .chart-card {
            background: #fff;
            border-radius: 0.75rem;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            animation: slideIn 0.5s ease-out 0.2s both;
        }

        .chart-header {
            background: linear-gradient(135deg, #f8fafc, #f1f5f9);
            padding: 1.5rem;
            border-bottom: 2px solid #e5e7eb;
        }

        .chart-header h5 {
            color: #1f2937;
            margin: 0;
        }

        .chart-body {
            padding: 1.5rem;
        }

        /* Upcoming Operations Table */
        .upcoming-operations-table {
            background: #fff;
            border-radius: 0.75rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            animation: slideIn 0.5s ease-out 0.3s both;
        }

        .upcoming-operations-table .table {
            margin-bottom: 0;
        }

        .upcoming-operations-table thead th {
            background: linear-gradient(135deg, #f8fafc, #f1f5f9);
            border-bottom: 2px solid #e5e7eb;
            font-weight: 600;
            color: #1f2937;
        }

        .upcoming-operations-table tbody tr {
            transition: all 0.2s ease;
        }

        .upcoming-operations-table tbody tr:hover {
            background-color: #f8fafc;
            box-shadow: 0 2px 4px rgba(16, 185, 129, 0.1);
        }

        .operation-row td {
            padding: 1rem;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
        }

        .terminate-btn {
            transition: all 0.3s ease;
            border: 1px solid #10b981;
            color: #10b981;
            padding: 0.375rem 0.75rem;
            font-size: 0.875rem;
        }

        .terminate-btn:hover {
            background: #10b981;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(16, 185, 129, 0.25);
        }

        .terminate-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        #refreshBtn {
            transition: all 0.3s ease;
        }

        #refreshBtn:hover {
            background: linear-gradient(135deg, #10b981, #059669);
            color: #fff;
            transform: translateY(-2px);
        }
    </style>
{% endblock %}
