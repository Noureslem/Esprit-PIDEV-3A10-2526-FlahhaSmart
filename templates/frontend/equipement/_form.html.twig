{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}

    {# Global form errors #}
    {% if form.vars.errors|length > 0 %}
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>{{ 'common.error'|trans }} :</strong> {{ 'common.please_fix_errors'|trans }}
        {{ form_errors(form) }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ 'common.close'|trans }}"></button>
    </div>
    {% endif %}

    <div class="mb-3">
        {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(form.nom, {
            'attr': {
                'class': 'form-control ' ~ (form.nom.vars.errors|length ? 'is-invalid' : ''),
                'placeholder': form.nom.vars.attr.placeholder|default('')|trans
            }
        }) }}
        {% if form.nom.vars.errors|length %}
        <div class="invalid-feedback d-block">
            {{ form_errors(form.nom) }}
        </div>
        {% endif %}
    </div>
    
    <div class="mb-3">
        {{ form_label(form.type, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
        {{ form_widget(form.type, {
            'attr': {
                'class': 'form-select ' ~ (form.type.vars.errors|length ? 'is-invalid' : '')
            }
        }) }}
        {% if form.type.vars.errors|length %}
        <div class="invalid-feedback d-block">
            {{ form_errors(form.type) }}
        </div>
        {% endif %}
    </div>

    {{ form_rest(form) }}
    
    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary px-4 py-2">
            <i class="bi bi-check-lg me-1"></i>
            {{ button_label|default('common.save'|trans) }}
        </button>
        {% if cancel_drawer|default(false) %}
            <button type="button" class="btn btn-outline-secondary px-4 py-2" data-action="right-drawer#close">
                <i class="bi bi-x-lg me-1"></i>
                {{ 'common.cancel'|trans }}
            </button>
        {% else %}
            <a href="{{ path('app_equipement_index') }}" class="btn btn-outline-secondary px-4 py-2">
                <i class="bi bi-x-lg me-1"></i>
                {{ 'common.cancel'|trans }}
            </a>
        {% endif %}
    </div>
{{ form_end(form) }}
