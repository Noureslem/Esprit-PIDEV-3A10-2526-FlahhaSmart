{% extends 'base.html.twig' %}

{% block body %}
    <div class="max-w-md mx-auto bg-white rounded-xl shadow-md p-6">
        <h1 class="text-2xl font-bold text-center text-gray-800 mb-6">Inscription</h1>
        {{ form_start(form) }}
        {{ form_row(form.email, {attr: {class: 'w-full border-gray-300 rounded-lg mb-4'}}) }}
        {{ form_row(form.plainPassword.first, {attr: {class: 'w-full border-gray-300 rounded-lg mb-4'}}) }}
        {{ form_row(form.plainPassword.second, {attr: {class: 'w-full border-gray-300 rounded-lg mb-4'}}) }}
        <button type="submit" class="w-full bg-green-600 text-white py-2 rounded-lg hover:bg-green-700">S'inscrire</button>
        {{ form_end(form) }}
        <p class="text-center text-gray-600 mt-4">Déjà inscrit ? <a href="{{ path('app_login') }}" class="text-green-600">Connectez-vous</a></p>
    </div>
{% endblock %}