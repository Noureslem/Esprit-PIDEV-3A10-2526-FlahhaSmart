{% extends 'admin/base_admin.html.twig' %}

{% block title %}Modifier le Commentaire - Admin{% endblock %}

{% block admin_body %}
    <div class="panel-header">
        <div class="panel-title">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
            Modifier le Commentaire #{{ commentaire.idCommentaire }}
        </div>
        <a href="{{ path('admin_commentaires') }}" class="btn btn-secondary" style="background: rgba(0,0,0,0.05); color: var(--text-muted);">Retour</a>
    </div>

    <div class="panel" style="max-width: 800px; margin: 0 auto;">
        <form method="post" action="{{ path('admin_commentaire_edit', {id: commentaire.idCommentaire}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('edit' ~ commentaire.idCommentaire) }}">

            <div style="margin-bottom: 1.5rem;">
                <label style="display: block; margin-bottom: 0.5rem; color: var(--text-muted); font-size: 0.875rem;">Auteur</label>
                <div style="padding: 0.75rem; background: rgba(0,0,0,0.02); border: 1px solid var(--border-color); border-radius: 0.5rem; color: var(--text-muted);">
                    {{ commentaire.auteur ? commentaire.auteur.email : 'Utilisateur Inconnu' }}
                </div>
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label for="contenu" style="display: block; margin-bottom: 0.5rem; color: var(--text-main); font-weight: 600;">Contenu du commentaire</label>
                <textarea id="contenu" name="contenu" rows="6" required style="width: 100%; padding: 0.75rem; border: 1px solid var(--border-color); border-radius: 0.5rem; font-family: var(--font-sans); resize: vertical;">{{ commentaire.contenu }}</textarea>
            </div>

            <div style="display: flex; justify-content: flex-end;">
                <button type="submit" class="btn btn-primary" style="padding: 0.75rem 1.5rem; font-size: 1rem;">
                    Enregistrer les modifications
                </button>
            </div>
        </form>
    </div>
{% endblock %}
