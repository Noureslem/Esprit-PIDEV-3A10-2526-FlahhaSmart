{% extends 'admin/base_admin.html.twig' %}

{% block title %}Gestion des utilisateurs - Admin{% endblock %}

{% block admin_body %}
    <div class="panel-header">
        <div class="panel-title">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            Gestion des Utilisateurs
        </div>
    </div>

    <div class="admin-table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nom & Prénom</th>
                    <th>Email</th>
                    <th>Toxicité</th>
                    <th>Rôle</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for user in users %}
                <tr>
                    <td>#{{ user.idUser }}</td>
                    <td>{{ user.nom }} {{ user.prenom }}</td>
                    <td>{{ user.email }}</td>
                    <td>
                        {% if user.toxicScore > 0 %}
                            <span class="mod-tag {% if user.toxicScore >= 3 %}bg-red-100 text-red-700{% else %}bg-orange-100 text-orange-700{% endif %}" style="display: inline-flex; align-items: center; gap: 0.25rem;">
                                {% if user.toxicScore >= 3 %}⚠️{% endif %}
                                {{ user.toxicScore }} contenu{{ user.toxicScore > 1 ? 's' : '' }} négatif{{ user.toxicScore > 1 ? 's' : '' }}
                            </span>
                        {% else %}
                            <span class="mod-tag" style="background: rgba(16,185,129,0.1); color: var(--success); opacity: 0.7;">Sain</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if user.role == 'ADMINISTRATEUR' %}
                            <span class="mod-tag" style="background: rgba(16,185,129,0.2); color: var(--success);">Admin</span>
                        {% else %}
                            {% if not user.actif %}
                                <span class="mod-tag" style="background: #fee2e2; color: #b91c1c;">BANNI</span>
                            {% else %}
                                <span class="mod-tag">Utilisateur</span>
                            {% endif %}
                        {% endif %}
                    </td>
                    <td>
                        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                            {% if user.role != 'ADMINISTRATEUR' %}
                                {% if user.actif %}
                                    <form method="post" action="{{ path('admin_user_ban', {id: user.idUser}) }}" onsubmit="return confirm('Voulez-vous vraiment BANNIRE cet utilisateur ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('ban' ~ user.idUser) }}">
                                        <button type="submit" class="btn btn-danger" style="padding: 0.25rem 0.5rem; font-size: 0.75rem; background: #dc2626;">Bannir</button>
                                    </form>
                                {% else %}
                                    <form method="post" action="{{ path('admin_user_unban', {id: user.idUser}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('unban' ~ user.idUser) }}">
                                        <button type="submit" class="btn btn-success" style="padding: 0.25rem 0.5rem; font-size: 0.75rem; background: #059669;">Rétablir accès</button>
                                    </form>
                                {% endif %}

                                <form method="post" action="{{ path('admin_user_promote', {id: user.idUser}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('promote' ~ user.idUser) }}">
                                    <button type="submit" class="btn btn-success" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;">Promouvoir Admin</button>
                                </form>
                            {% else %}
                                <form method="post" action="{{ path('admin_user_demote', {id: user.idUser}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('demote' ~ user.idUser) }}">
                                    <button type="submit" class="btn btn-danger" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;">Rétrograder</button>
                                </form>
                            {% endif %}
                            
                            <!-- Bouton Notification Mail -->
                            <form method="post" action="{{ path('admin_user_notify', {id: user.idUser}) }}" style="display: flex; gap: 0.25rem; align-items: center;">
                                <input type="hidden" name="_token" value="{{ csrf_token('notify' ~ user.idUser) }}">
                                <input type="text" name="message" placeholder="Avertissement..." style="padding: 0.25rem; font-size: 0.75rem; border: 1px solid var(--border-color); border-radius: 4px; width: 120px;">
                                <button type="submit" class="btn btn-primary" style="padding: 0.25rem 0.5rem; font-size: 0.75rem; background: #3b82f6;">Email</button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" style="text-align:center; padding: 2rem; color: var(--text-muted);">Aucun utilisateur trouvé.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="navigation" style="margin-top: 1.5rem; display: flex; justify-content: center;">
            {{ knp_pagination_render(users) }}
        </div>
    </div>
{% endblock %}