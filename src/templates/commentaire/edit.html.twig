{% extends 'base.html.twig' %}

{% block title %}Modifier le commentaire - FlahaSmart{% endblock %}

{% block stylesheets %}
<style>
    .premium-card { background: #fff; border-radius: 16px; box-shadow: 0 1px 6px rgba(0,0,0,.07); border: 1px solid #f1f5f9; }
    .brand-btn { background: #16a34a; color: #fff; border: none; border-radius: 12px; padding: .6rem 1.5rem; font-weight: 700; font-size: .9rem; transition: .2s; cursor: pointer; }
    .brand-btn:hover { background: #15803d; color: #fff; transform: translateY(-1px); }
    .form-control { border-radius: 12px; border: 1px solid #e2e8f0; padding: .75rem 1rem; transition: .2s; width: 100%; }
    .form-control:focus { outline: none; border-color: #16a34a; box-shadow: 0 0 0 3px rgba(22,163,74,.1); }
</style>
{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="premium-card overflow-hidden">
            <div style="height:4px;background:linear-gradient(90deg,#3b82f6,#16a34a);"></div>
            <div class="p-4 p-md-5">
                <h2 class="fw-black mb-1"><i class="fas fa-edit text-success me-2"></i>Modifier le commentaire</h2>
                <p class="text-muted small mb-4">Apportez les modifications souhaitées à votre commentaire.</p>

                <form method="post" novalidate>
                    <div class="mb-4">
                        <textarea name="contenu" rows="5" class="form-control" required>{{ commentaire.contenu }}</textarea>
                    </div>
                    <div class="d-flex justify-content-end gap-3">
                        <a href="{{ path('thread_show', {id: commentaire.thread.idThread}) }}"
                           class="btn btn-light rounded-3 fw-bold">Annuler</a>
                        <button type="submit" class="brand-btn">
                            <i class="fas fa-save me-2"></i>Enregistrer
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}