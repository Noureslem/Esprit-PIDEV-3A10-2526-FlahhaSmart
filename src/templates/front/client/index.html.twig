{% extends 'base.html.twig' %}
{% block title %}Boutique des Produits{% endblock %}
{% block body %}
    <div class="text-center mb-4 mt-2">
        <h1 class="text-success fw-bold display-6"><i class="fa-solid fa-store me-3"></i>Nos Produits Récoltés</h1>
        <p class="text-muted">Parcourez notre catalogue et découvrez nos variétés exclusives directement des producteurs.</p>
    </div>

    <!-- SECTION STATISTIQUES (inchangée) -->
    <div class="row g-2 mb-4 justify-content-center">
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm rounded-3 text-center p-2 bg-warning bg-opacity-10">
                <div class="card-body p-2">
                    <div class="d-flex align-items-center justify-content-center gap-2">
                        <i class="fa-solid fa-spinner fa-spin fs-4 text-warning"></i>
                        <div>
                            <h6 class="text-warning fw-bold mb-0 small">En cours</h6>
                            <h4 class="fw-bold text-dark mb-0">{{ stats.en_cours }}</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm rounded-3 text-center p-2 bg-success bg-opacity-10">
                <div class="card-body p-2">
                    <div class="d-flex align-items-center justify-content-center gap-2">
                        <i class="fa-solid fa-check-circle fs-4 text-success"></i>
                        <div>
                            <h6 class="text-success fw-bold mb-0 small">Terminé</h6>
                            <h4 class="fw-bold text-dark mb-0">{{ stats.termine }}</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm rounded-3 text-center p-2 bg-primary bg-opacity-10">
                <div class="card-body p-2">
                    <div class="d-flex align-items-center justify-content-center gap-2">
                        <i class="fa-solid fa-chart-line fs-4 text-primary"></i>
                        <div>
                            <h6 class="text-primary fw-bold mb-0 small">En croissance</h6>
                            <h4 class="fw-bold text-dark mb-0">{{ stats.en_croissance }}</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-0 shadow-sm rounded-3 text-center p-2 bg-secondary bg-opacity-10">
                <div class="card-body p-2">
                    <div class="d-flex align-items-center justify-content-center gap-2">
                        <i class="fa-solid fa-chart-simple fs-4 text-secondary"></i>
                        <div>
                            <h6 class="text-secondary fw-bold mb-0 small">Total</h6>
                            <h4 class="fw-bold text-dark mb-0">{{ stats.total }}</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FILTRE PAR STATUT (version serveur) -->
    <div class="row justify-content-center mb-4">
        <div class="col-md-8 col-lg-6">
            <div class="d-flex gap-2 justify-content-center flex-wrap">
                <a href="{{ path('client_produit_index', {status: 'all', search: currentSearch}) }}" 
                   class="btn btn-sm {% if currentStatus == 'all' %}btn-success{% else %}btn-outline-success{% endif %} rounded-pill px-3">
                    <i class="fa-solid fa-border-all me-1"></i>Tous ({{ stats.total }})
                </a>
                <a href="{{ path('client_produit_index', {status: 'en cours', search: currentSearch}) }}" 
                   class="btn btn-sm {% if currentStatus == 'en cours' %}btn-warning text-dark{% else %}btn-outline-warning{% endif %} rounded-pill px-3">
                    <i class="fa-solid fa-spinner me-1"></i>En cours ({{ stats.en_cours }})
                </a>
                <a href="{{ path('client_produit_index', {status: 'terminé', search: currentSearch}) }}" 
                   class="btn btn-sm {% if currentStatus == 'terminé' %}btn-success{% else %}btn-outline-success{% endif %} rounded-pill px-3">
                    <i class="fa-solid fa-check-circle me-1"></i>Terminé ({{ stats.termine }})
                </a>
                <a href="{{ path('client_produit_index', {status: 'en croissance', search: currentSearch}) }}" 
                   class="btn btn-sm {% if currentStatus == 'en croissance' %}btn-primary{% else %}btn-outline-primary{% endif %} rounded-pill px-3">
                    <i class="fa-solid fa-chart-line me-1"></i>En croissance ({{ stats.en_croissance }})
                </a>
            </div>
        </div>
    </div>

    <!-- BARRE DE RECHERCHE -->
    <div class="row justify-content-center mb-4">
        <div class="col-md-6 col-lg-5">
            <form method="get" action="{{ path('client_produit_index') }}" class="input-group shadow-sm" style="border-radius: 50px; overflow:hidden;">
                <input type="hidden" name="status" value="{{ currentStatus }}">
                <span class="input-group-text bg-white border-0 text-success px-3"><i class="fa-solid fa-search"></i></span>
                <input type="text" name="search" class="form-control border-0" placeholder="Rechercher une variété, un produit..." value="{{ currentSearch }}">
                <button type="submit" class="btn btn-success">OK</button>
                {% if currentSearch %}
                    <a href="{{ path('client_produit_index', {status: currentStatus}) }}" class="btn btn-outline-secondary">Réinitialiser</a>
                {% endif %}
            </form>
        </div>
    </div>

    <!-- LISTE DES PRODUITS (paginated) -->
    <div class="row row-cols-1 row-cols-md-3 row-cols-xl-4 g-4 mb-5">
        {% for stock in stocks %}
            <div class="col">
                <div class="card h-100 border-0 shadow-sm custom-hover-card" style="border-radius: 16px;">
                    <div class="card-body text-center p-3">
                        <div class="mb-2">
                            {% set statut = stock.statut|default('standard')|lower %}
                            {% if statut == 'en cours' or statut == 'en_cours' %}
                                <span class="badge bg-warning text-dark rounded-pill px-2 py-1 small">
                                    <i class="fa-solid fa-spinner fa-spin me-1"></i>En cours
                                </span>
                            {% elseif statut == 'terminé' or statut == 'termine' %}
                                <span class="badge bg-success rounded-pill px-2 py-1 small">
                                    <i class="fa-solid fa-check-circle me-1"></i>Terminé
                                </span>
                            {% elseif statut == 'en croissance' or statut == 'en_croissance' %}
                                <span class="badge bg-primary rounded-pill px-2 py-1 small">
                                    <i class="fa-solid fa-chart-line me-1"></i>En croissance
                                </span>
                            {% else %}
                                <span class="badge bg-secondary rounded-pill px-2 py-1 small">
                                    {{ stock.statut|default('standard')|capitalize }}
                                </span>
                            {% endif %}
                        </div>
                        <div class="display-6 text-success mb-2 opacity-25">
                            <i class="fa-brands fa-pagelines"></i>
                        </div>
                        <h5 class="card-title fw-bold text-dark mb-1">{{ stock.typeProduit|default('?') }}</h5>
                        <h6 class="text-muted small mb-2">{{ stock.variete|default('Variété inconnue') }}</h6>
                        <hr class="w-50 mx-auto text-success opacity-25 my-2">
                        <p class="small text-secondary mb-0">
                            <strong><i class="fa-solid fa-user me-1"></i> Producteur :</strong><br>
                            {{ stock.user ? stock.user.nom ~ ' ' ~ stock.user.prenom : 'Coopérative' }}
                        </p>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3 text-center">
                        <a href="{{ path('client_produit_show', {'idProduit': stock.idProduit}) }}" class="btn btn-success btn-sm rounded-pill shadow-sm px-3">
                            Voir Détails <i class="fa-solid fa-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <i class="fa-solid fa-basket-shopping text-muted fa-3x mb-3 opacity-25"></i>
                <h4 class="text-muted">Aucun produit ne correspond à vos critères.</h4>
            </div>
        {% endfor %}
    </div>

    <!-- PAGINATION -->
    <div class="d-flex justify-content-center mt-3">
        {{ knp_pagination_render(stocks) }}
    </div>


   

  
{% endblock %}