{# Chatbot Widget Component #}
<div class="chatbot-container"
     data-controller="chatbot"
     data-chatbot-endpoint-value="{{ path('app_chatbot_ask') }}"
     data-chatbot-csrf-token-value="{{ csrf_token('ajax') }}">

  <!-- Floating Button -->
  <button class="chatbot-toggle"
          data-action="chatbot#toggleWidget"
          data-chatbot-target="toggle"
          type="button"
          aria-label="Open chatbot"
          title="Agricultural Assistant">
    <svg class="chatbot-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
    <span class="chatbot-badge">💬</span>
  </button>

  <!-- Chatbot Widget -->
  <div class="chatbot-widget" data-chatbot-target="widget">
    <!-- Header -->
    <div class="chatbot-header">
      <div class="chatbot-header-content">
        <h3 class="chatbot-title">🌾 AgriBot</h3>
      </div>
      <button class="chatbot-close"
              data-action="chatbot#closeWidget"
              type="button"
              aria-label="Close chatbot"
              title="Close">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Messages Container -->
    <div class="chatbot-messages" data-chatbot-target="messages"></div>

    <!-- Loader -->
    <div class="chatbot-loader" data-chatbot-target="loader">
      <div class="loader-dots">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </div>

    <!-- Input Area -->
    <div class="chatbot-footer">
      <form class="chatbot-input-form" data-action="chatbot#sendMessage">
        <input type="text"
               class="chatbot-input"
               data-chatbot-target="message"
               data-action="keydown@window->chatbot#handleKeyDown"
               placeholder="Ask about farming, crops, soil..."
               autocomplete="off"
               aria-label="Message input">
        <button class="chatbot-send"
                data-chatbot-target="send"
                type="submit"
                aria-label="Send message"
                title="Send (Enter)">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M16.6915026,12.4744748 L3.50612381,13.2599618 C3.19218622,13.2599618 3.03521743,13.4170592 3.03521743,13.5741566 L1.15159189,20.0151496 C0.8376543,20.8006365 0.99,21.89 1.77946707,22.52 C2.41,22.99 3.50612381,23.1 4.13399899,22.9429026 L21.714504,14.0454487 C22.6563168,13.5741566 23.1272231,12.6315722 22.9702544,11.6889879 L4.13399899,1.11157075 C3.34915502,0.9544732 2.40734225,1.0656731 1.77946707,1.4429468 C0.994623095,2.0772931 0.837654326,3.16923127 1.15159189,3.95471808 L3.03521743,10.3957111 C3.03521743,10.5528085 3.19218622,10.7099059 3.50612381,10.7099059 L16.6915026,11.4953929 C16.6915026,11.4953929 17.1624089,11.4953929 17.1624089,11.0181392 L17.1624089,12.4744748 C17.1624089,12.4744748 17.1624089,12.4744748 16.6915026,12.4744748 Z"></path>
          </svg>
        </button>
      </form>
      <div class="chatbot-footer-actions">
        <button class="chatbot-clear-btn" 
                data-action="chatbot#clearHistory"
                type="button"
                title="Clear history">
          Clear
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  :root {
    --chatbot-primary: #10b981;
    --chatbot-primary-dark: #059669;
    --chatbot-secondary: #064e3b;
    --chatbot-user-bg: #e8f5e9;
    --chatbot-bot-bg: #f0f9ff;
    --chatbot-border: #e5e7eb;
    --chatbot-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    --chatbot-radius: 12px;
  }

  .chatbot-container {
    position: fixed;
    bottom: 20px;
    right: 20px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    z-index: 9999;
  }

  /* Toggle Button */
  .chatbot-toggle {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--chatbot-primary);
    border: none;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--chatbot-shadow);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 10;
  }

  .chatbot-toggle:hover {
    background: var(--chatbot-primary-dark);
    transform: scale(1.1);
  }

  .chatbot-toggle:active {
    transform: scale(0.95);
  }

  .chatbot-icon {
    width: 28px;
    height: 28px;
  }

  .chatbot-badge {
    position: absolute;
    font-size: 18px;
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }

  /* Widget */
  .chatbot-widget {
    position: absolute;
    bottom: 80px;
    right: 0;
    width: 380px;
    height: 600px;
    background: white;
    border-radius: var(--chatbot-radius);
    box-shadow: var(--chatbot-shadow);
    display: flex;
    flex-direction: column;
    opacity: 0;
    visibility: hidden;
    transform: translateY(20px) scale(0.95);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 9;
  }

  .chatbot-widget.chatbot-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  /* Header */
  .chatbot-header {
    padding: 16px;
    background: linear-gradient(135deg, var(--chatbot-primary) 0%, var(--chatbot-primary-dark) 100%);
    color: white;
    border-radius: var(--chatbot-radius) var(--chatbot-radius) 0 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 10px;
    flex-shrink: 0;
  }

  .chatbot-header-content {
    flex: 1;
  }

  .chatbot-title {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
  }

  .chatbot-subtitle {
    margin: 4px 0 0 0;
    font-size: 12px;
    opacity: 0.85;
    font-weight: 400;
  }

  .chatbot-close {
    width: 32px;
    height: 32px;
    background: rgba(255, 255, 255, 0.2);
    border: none;
    color: white;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .chatbot-close:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .chatbot-close svg {
    width: 18px;
    height: 18px;
  }

  /* Messages */
  .chatbot-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: #fafafa;
  }

  .message {
    display: flex;
    flex-direction: column;
    gap: 4px;
    animation: slideIn 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .message-user {
    align-items: flex-end;
  }

  .message-bot {
    align-items: flex-start;
  }

  .message-bubble {
    max-width: 85%;
    padding: 10px 14px;
    border-radius: 12px;
    word-wrap: break-word;
    line-height: 1.4;
    font-size: 14px;
  }

  .message-user .message-bubble {
    background: var(--chatbot-primary);
    color: white;
    border-radius: 12px 0 12px 12px;
  }

  .message-bot .message-bubble {
    background: white;
    color: #1f2937;
    border: 1px solid var(--chatbot-border);
    border-radius: 0 12px 12px 12px;
  }

  .message.error .message-bubble {
    background: #fee;
    color: #c33;
    border-color: #fcc;
  }

  .message-time {
    font-size: 12px;
    color: #999;
    padding: 0 4px;
  }

  /* Loader */
  .chatbot-loader {
    padding: 16px;
    display: none;
    justify-content: center;
    align-items: center;
  }

  .chatbot-loader.visible {
    display: flex;
  }

  .loader-dots {
    display: flex;
    gap: 4px;
  }

  .loader-dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--chatbot-primary);
    animation: bounce 1.4s infinite;
  }

  .loader-dots span:nth-child(2) {
    animation-delay: 0.2s;
  }

  .loader-dots span:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes bounce {
    0%, 100% {
      transform: translateY(0);
      opacity: 1;
    }
    50% {
      transform: translateY(-10px);
      opacity: 0.5;
    }
  }

  /* Footer */
  .chatbot-footer {
    padding: 12px;
    border-top: 1px solid var(--chatbot-border);
    background: white;
    border-radius: 0 0 var(--chatbot-radius) var(--chatbot-radius);
    flex-shrink: 0;
  }

  .chatbot-input-form {
    display: flex;
    gap: 8px;
    margin-bottom: 8px;
  }

  .chatbot-input {
    flex: 1;
    padding: 10px 12px;
    border: 1px solid var(--chatbot-border);
    border-radius: 8px;
    font-size: 14px;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
    resize: none;
  }

  .chatbot-input:focus {
    border-color: var(--chatbot-primary);
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
  }

  .chatbot-send {
    width: 36px;
    height: 36px;
    background: var(--chatbot-primary);
    border: none;
    color: white;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .chatbot-send:hover:not(:disabled) {
    background: var(--chatbot-primary-dark);
    transform: scale(1.05);
  }

  .chatbot-send:active:not(:disabled) {
    transform: scale(0.95);
  }

  .chatbot-send:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .chatbot-send svg {
    width: 18px;
    height: 18px;
  }

  .chatbot-footer-actions {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
  }

  .chatbot-clear-btn {
    padding: 4px 8px;
    font-size: 12px;
    background: transparent;
    border: 1px solid var(--chatbot-border);
    border-radius: 4px;
    cursor: pointer;
    color: #666;
    transition: all 0.2s;
  }

  .chatbot-clear-btn:hover {
    background: #f5f5f5;
    border-color: #999;
  }

  /* Scroll bar styling */
  .chatbot-messages::-webkit-scrollbar {
    width: 6px;
  }

  .chatbot-messages::-webkit-scrollbar-track {
    background: transparent;
  }

  .chatbot-messages::-webkit-scrollbar-thumb {
    background: #ccc;
    border-radius: 3px;
  }

  .chatbot-messages::-webkit-scrollbar-thumb:hover {
    background: #999;
  }

  /* Responsive */
  @media (max-width: 480px) {
    .chatbot-container {
      bottom: 10px;
      right: 10px;
    }

    .chatbot-widget {
      width: calc(100vw - 20px);
      height: 70vh;
      max-height: 500px;
      bottom: 70px;
    }

    .chatbot-toggle {
      width: 50px;
      height: 50px;
    }
  }

  /* RTL Support */
  [dir="rtl"] .chatbot-container {
    right: auto;
    left: 20px;
  }

  [dir="rtl"] .chatbot-message-user {
    align-items: flex-start;
  }

  [dir="rtl"] .chatbot-message-bot {
    align-items: flex-end;
  }

  [dir="rtl"] .message-user .message-bubble {
    border-radius: 0 12px 12px 12px;
  }

  [dir="rtl"] .message-bot .message-bubble {
    border-radius: 12px 0 12px 12px;
  }
</style>
