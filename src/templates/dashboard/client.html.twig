{% extends 'base.html.twig' %}
{% block title %}Dashboard Client — FlahaSmart{% endblock %}
{% block page_title %}Mon espace client{% endblock %}

{% block body %}

<div class="mb-4">
    <h4>Bonjour, {{ user.fullName }} 👋</h4>
    <p class="text-muted">{{ user.email }}</p>
</div>

<div class="card mb-4">
    <div class="card-header bg-white border-0 pt-3 pb-0">
        <h5 class="mb-0">Mes services</h5>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-6 col-md-4">
                <a href="{{ path('app_shop_index') }}"
                   class="card text-decoration-none text-center p-4 h-100 hover-shadow">
                    <div class="fs-2 mb-2">🛒</div>
                    <h5 class="mb-0">Boutique</h5>
                    <p class="text-muted small mt-2 mb-0">Parcourir les articles</p>
                </a>
            </div>
            <div class="col-6 col-md-4">
                <a href="{{ path('app_cart_index') }}"
                   class="card text-decoration-none text-center p-4 h-100 hover-shadow">
                    <div class="fs-2 mb-2">🛍️</div>
                    <h5 class="mb-0">Panier</h5>
                    <p class="text-muted small mt-2 mb-0">Voir vos achats en cours</p>
                </a>
            </div>
            {# ── Bouton Forum Client ──────────────────────────────────────── #}
            <div class="col-6 col-md-4">
                <a href="{{ path('thread_index') }}"
                   class="card text-decoration-none text-center p-4 h-100 hover-shadow">
                    <div class="fs-2 mb-2">💬</div>
                    <h5 class="mb-0">Forum</h5>
                    <p class="text-muted small mt-2 mb-0">Rejoindre la communauté</p>
                </a>
            </div>
            {# ─────────────────────────────────────────────────────────────── #}
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header bg-white border-0 pt-3 pb-0">
        <h5 class="mb-0">Mes commandes</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Référence</th>
                        <th>Date</th>
                        <th>Statut</th>
                        <th>Paiement</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                {% for c in commandes %}
                    <tr>
                        <td><strong>{{ c.reference }}</strong></td>
                        <td class="text-muted small">{{ c.date_commande|date('d/m/Y') }}</td>
                        <td>
                            <span class="badge {% if c.statut == 'Delivré' %}bg-success
                                {% elseif c.statut == 'En Cours' %}bg-warning text-dark
                                {% else %}bg-secondary{% endif %}">
                                {{ c.statut }}
                            </span>
                        </td>
                        <td>{{ c.mode_paiement }}</td>
                        <td><strong>{{ c.montant_total }} DT</strong></td>
                    </tr>
                {% else %}
                    <tr><td colspan="5" class="text-center text-muted py-3">Aucune commande</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% endblock %}
