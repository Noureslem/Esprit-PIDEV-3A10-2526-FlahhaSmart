{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin — FlahaSmart{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet">
<style>
    :root {
        --admin-primary: #1e4620;
        --admin-secondary: #4c8b3c;
        --admin-bg: #fef9f0;
        --card-shadow: 0 20px 35px -10px rgba(0,0,0,0.08);
    }
    body {
        background: var(--admin-bg);
    }
    .admin-hero {
        background: linear-gradient(105deg, #1e4620 0%, #2a6e2a 100%);
        border-radius: 0 0 3rem 3rem;
        padding: 2rem 0;
        margin-bottom: 2rem;
        color: white;
        position: relative;
        overflow: hidden;
    }
    .admin-hero::after {
        content: "";
        position: absolute;
        inset: auto -80px -80px auto;
        width: 220px;
        height: 220px;
        border-radius: 50%;
        background: rgba(255,255,255,0.08);
    }
    .kpi-card,
    .widget,
    .modern-table {
        background: white;
        border-radius: 1.5rem;
        box-shadow: var(--card-shadow);
        border: 1px solid rgba(0,0,0,0.03);
    }
    .kpi-card {
        padding: 1.2rem;
        transition: all 0.3s;
        height: 100%;
        border-radius: 1rem;
        position: relative;
        overflow: hidden;
    }
    .kpi-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--card-accent), transparent);
    }
    .kpi-card:nth-child(1) { --card-accent: #4CAF50; }
    .kpi-card:nth-child(2) { --card-accent: #2196F3; }
    .kpi-card:nth-child(3) { --card-accent: #FF9800; }
    .kpi-card:nth-child(4) { --card-accent: #E91E63; }
    .kpi-card:nth-child(5) { --card-accent: #9C27B0; }
    .kpi-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1);
    }
    .kpi-icon {
        width: 55px;
        height: 55px;
        background: rgba(30,70,32,0.1);
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        color: var(--admin-primary);
    }
    .kpi-value {
        font-size: 2rem;
        font-weight: 800;
        color: var(--admin-primary);
        line-height: 1.2;
    }
    .widget {
        padding: 1.2rem;
        height: 100%;
    }
    .widget-title {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }
    .widget-kicker {
        font-size: 0.78rem;
        color: #6b7280;
    }
    .quick-btn {
        background: #f1f5f9;
        border: none;
        border-radius: 2rem;
        padding: 0.5rem 1rem;
        font-weight: 500;
        transition: 0.2s;
        color: #1f2937;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
    .quick-btn:hover {
        background: var(--admin-primary);
        color: white;
        transform: translateY(-2px);
    }
    .metric-strip {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.8rem;
        margin-top: 1rem;
    }
    .metric-pill {
        background: #f7faf7;
        border: 1px solid #e5efe5;
        border-radius: 1rem;
        padding: 0.9rem;
        text-align: center;
    }
    .metric-pill strong {
        display: block;
        font-size: 1.15rem;
        color: var(--admin-primary);
    }
    .insight-box {
        background: linear-gradient(135deg, #173723 0%, #245236 100%);
        color: white;
        border-radius: 1.4rem;
        padding: 1.2rem;
    }
    .modern-table {
        overflow: hidden;
    }
    .modern-table thead {
        background: #f8f9fc;
    }
    .modern-table thead th {
        border-bottom: 2px solid #e9ecef;
        padding: 1rem;
        font-weight: 600;
        color: #2d3748;
    }
    .modern-table tbody td {
        padding: 1rem;
        vertical-align: middle;
    }
    .badge-custom {
        padding: 0.3rem 0.8rem;
        border-radius: 2rem;
        font-weight: 500;
        font-size: 0.75rem;
    }
    .badge-admin { background: #fef3c7; color: #b45309; }
    .badge-agri { background: #dcfce7; color: #166534; }
    .badge-client { background: #e0f2fe; color: #0369a1; }
    .avatar-sm {
        width: 35px;
        height: 35px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid white;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
    .hero-actions {
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .hero-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.7rem 1rem;
        border-radius: 999px;
        text-decoration: none;
        transition: 0.2s ease;
    }
    .hero-pill-date {
        background: rgba(255,255,255,0.2);
        color: white;
    }
    .hero-pill-date:hover {
        color: white;
        background: rgba(255,255,255,0.28);
    }
    .hero-pill-logout {
        background: rgba(128, 24, 24, 0.18);
        border: 1px solid rgba(255,255,255,0.18);
        color: white;
    }
    .hero-pill-logout:hover {
        color: white;
        background: rgba(190, 24, 24, 0.32);
    }
    .forum-card {
        background: white;
        border-radius: 1.5rem;
        transition: 0.2s;
    }
    .forum-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--card-shadow);
    }
    @media (max-width: 768px) {
        .admin-hero { padding: 1.5rem 0; }
        .kpi-value { font-size: 1.5rem; }
        .metric-strip { grid-template-columns: 1fr; }
        .hero-actions { justify-content: flex-start; margin-top: 1rem; }
    }
</style>
{% endblock %}

{% block body %}
<div class="admin-hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="d-flex align-items-center gap-3">
                    <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png" width="65" class="bg-white rounded-circle p-2 shadow" alt="Admin">
                    <div>
                        <h1 class="display-6 fw-bold mb-1">Bonjour, {{ app.user.prenom }}</h1>
                        <p class="mb-0 opacity-75">Gérez efficacement votre plateforme FlahaSmart : utilisateurs, commandes, forum et analyses.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <div class="hero-actions">
                    <span class="hero-pill hero-pill-date">
                        <i class="fas fa-calendar-alt"></i>{{ "now"|date("d/m/Y") }}
                    </span>
                    <a href="{{ path('app_logout') }}" class="hero-pill hero-pill-logout">
                        <i class="fas fa-right-from-bracket"></i>Déconnexion
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    {# ── KPI Cards (utilisateurs, commandes, threads, actifs, inactifs) ── #}
    <div class="row g-4 mb-5" data-aos="fade-up">
        <div class="col-lg-3 col-md-6 col-6">
            <div class="kpi-card d-flex align-items-center">
                <div class="kpi-icon me-3"><i class="fas fa-users"></i></div>
                <div>
                    <div class="kpi-value">{{ stats.users }}</div>
                    <small>Utilisateurs</small>
                    <div class="small text-muted">{{ stats.admins ?? 0 }} admins, {{ stats.farmers ?? 0 }} agriculteurs</div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 col-6">
            <div class="kpi-card d-flex align-items-center">
                <div class="kpi-icon me-3"><i class="fas fa-shopping-cart"></i></div>
                <div>
                    <div class="kpi-value">{{ stats.commandes ?? 0 }}</div>
                    <small>Commandes</small>
                    <div class="small text-info">à traiter</div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 col-6">
            <div class="kpi-card d-flex align-items-center">
                <div class="kpi-icon me-3"><i class="fas fa-comments"></i></div>
                <div>
                    <div class="kpi-value">{{ stats.threads ?? 0 }}</div>
                    <small>Threads forum</small>
                    <div class="small text-warning">à modérer</div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 col-6">
            <div class="kpi-card d-flex align-items-center">
                <div class="kpi-icon me-3"><i class="fas fa-user-check"></i></div>
                <div>
                    <div class="kpi-value">{{ stats.activeUsers ?? 0 }}</div>
                    <small>Utilisateurs actifs</small>
                    <div class="small text-success">{{ stats.activeRate ?? 0 }}% du total</div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 col-6">
            <div class="kpi-card d-flex align-items-center">
                <div class="kpi-icon me-3"><i class="fas fa-user-slash"></i></div>
                <div>
                    <div class="kpi-value">{{ stats.inactiveUsers ?? 0 }}</div>
                    <small>Inactifs</small>
                    <div class="small text-danger">à relancer</div>
                </div>
            </div>
        </div>
    </div>

    {# ── Notifications et actions rapides ── #}
    <div class="row g-4 mb-5" data-aos="fade-up">
        <div class="col-lg-7">
            <div class="widget">
                <div class="widget-title">
                    <div>
                        <h6 class="fw-bold mb-1"><i class="fas fa-bell text-success me-2"></i>Notifications admin</h6>
                        <div class="widget-kicker">Dernières alertes de création de compte</div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-success rounded-pill">{{ unreadNotifications|default(0) }} non lues</span>
                        <a href="{{ path('admin_notifications') }}" class="btn btn-sm btn-outline-success rounded-pill">Voir tout <i class="fas fa-arrow-right ms-1"></i></a>
                    </div>
                </div>
                <div class="list-group">
                    {% if notifications is defined and notifications|length > 0 %}
                        {% for note in notifications %}
                            <a href="{{ path('admin_notifications') }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="fw-semibold">{{ note.message }}</div>
                                    <small class="text-muted">{{ note.dateNotif ? note.dateNotif|date('d/m/Y H:i') : '-' }}</small>
                                </div>
                                {% if not note.lu %}
                                    <span class="badge bg-warning text-dark rounded-pill">Nouveau</span>
                                {% endif %}
                            </a>
                        {% endfor %}
                    {% else %}
                        <div class="list-group-item text-center text-muted">
                            Aucune notification récente.
                        </div>
                    {% endif %}
                </div>
                <div class="mt-4">
                    <h6 class="fw-bold mb-2"><i class="fas fa-bolt me-2"></i>Actions rapides</h6>
                    <div class="d-flex flex-wrap gap-2">
                        <a href="{{ path('admin_user_new') }}" class="quick-btn"><i class="fas fa-user-plus me-1"></i>Ajouter un utilisateur</a>
                        <a href="{{ path('admin_users') }}" class="quick-btn"><i class="fas fa-users me-1"></i>Liste des utilisateurs</a>
                        <a href="{{ path('dashboard_admin_report') }}" class="quick-btn"><i class="fas fa-file-pdf me-1"></i>Rapport PDF</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="widget">
                <div class="widget-title">
                    <div>
                        <h6 class="fw-bold mb-1"><i class="fas fa-chart-line me-2 text-success"></i>Inscriptions (7 derniers jours)</h6>
                        <div class="widget-kicker">Évolution récente des créations de comptes</div>
                    </div>
                </div>
                <canvas id="activityChart" height="180"></canvas>
            </div>
        </div>
    </div>

    {# ── Graphiques de répartition (si données disponibles) ── #}
    <div class="row g-4 mb-5">
        <div class="col-lg-4" data-aos="fade-up">
            <div class="widget">
                <div class="widget-title">
                    <div>
                        <h6 class="fw-bold mb-1"><i class="fas fa-chart-pie me-2 text-success"></i>Répartition des rôles</h6>
                    </div>
                </div>
                <canvas id="rolesChart" height="220"></canvas>
            </div>
        </div>
        <div class="col-lg-4" data-aos="fade-up" data-aos-delay="80">
            <div class="widget">
                <div class="widget-title">
                    <div>
                        <h6 class="fw-bold mb-1"><i class="fas fa-chart-pie me-2 text-success"></i>État des comptes</h6>
                    </div>
                </div>
                <canvas id="statusChart" height="220"></canvas>
            </div>
        </div>
        <div class="col-lg-4" data-aos="fade-up" data-aos-delay="160">
            <div class="widget">
                <div class="widget-title">
                    <div>
                        <h6 class="fw-bold mb-1"><i class="fas fa-chart-column me-2 text-success"></i>Inscriptions mensuelles (6 mois)</h6>
                    </div>
                </div>
                <canvas id="monthlyChart" height="220"></canvas>
            </div>
        </div>
    </div>

    {# ── Carte Modération Forum (issue du deuxième template) ── #}
    <div class="row g-4 mb-5">
        <div class="col-12">
            <div class="forum-card p-4 d-flex align-items-center gap-3 flex-wrap justify-content-between">
                <div class="d-flex align-items-center gap-3">
                    <span style="font-size:2rem;">🛡️</span>
                    <div>
                        <h5 class="mb-0">Modération Forum</h5>
                        <p class="text-muted small mb-0">Gérez les threads, commentaires, utilisateurs et la modération IA du forum.</p>
                    </div>
                </div>
                <a href="{{ path('forum_admin_dashboard') }}" class="btn btn-warning text-dark fw-semibold rounded-pill px-4">
                    Modération Forum →
                </a>
            </div>
        </div>
    </div>

    {# ── Tableau des derniers inscrits ── #}
    <div class="modern-table mb-5" data-aos="fade-up">
        <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
            <h6 class="fw-bold mb-0"><i class="fas fa-user-plus text-success me-2"></i>Derniers inscrits</h6>
            <a href="{{ path('admin_users') }}" class="btn btn-sm btn-outline-success rounded-pill">Voir tout <i class="fas fa-arrow-right ms-1"></i></a>
        </div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Utilisateur</th>
                        <th>Email</th>
                        <th>Rôle</th>
                        <th>Statut</th>
                        <th>Date</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                {% for u in lastUsers %}
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="https://randomuser.me/api/portraits/{{ u.id % 2 == 0 ? 'women' : 'men' }}/{{ u.id % 70 }}.jpg" class="avatar-sm" alt="{{ u.prenom }} {{ u.nom }}" onerror="this.src='https://ui-avatars.com/api/?background=4c8b3c&color=fff&name={{ u.prenom }}+{{ u.nom }}'">
                                <div>
                                    <strong>{{ u.prenom }} {{ u.nom }}</strong>
                                    {% if u.id == app.user.id %}<span class="badge bg-info ms-1">Vous</span>{% endif %}
                                </div>
                            </div>
                        </td>
                        <td>{{ u.email }}</td>
                        <td>
                            <span class="badge-custom {% if u.role in ['ROLE_ADMIN', 'ADMINISTRATEUR'] %}badge-admin{% elseif u.role in ['ROLE_AGRICULTEUR', 'AGRICULTEUR'] %}badge-agri{% else %}badge-client{% endif %}">
                                {% if u.role in ['ROLE_ADMIN', 'ADMINISTRATEUR'] %}<i class="fas fa-crown me-1"></i>Admin
                                {% elseif u.role in ['ROLE_AGRICULTEUR', 'AGRICULTEUR'] %}<i class="fas fa-tractor me-1"></i>Agriculteur
                                {% else %}<i class="fas fa-user me-1"></i>Client{% endif %}
                            </span>
                        </td>
                        <td>
                            <span class="badge-custom {% if u.actif %}bg-success text-white{% else %}bg-secondary text-white{% endif %}">
                                <i class="fas {{ u.actif ? 'fa-check-circle' : 'fa-ban' }} me-1"></i>{{ u.actif ? 'Actif' : 'Inactif' }}
                            </span>
                        </td>
                        <td class="text-muted"><i class="far fa-calendar-alt me-1"></i>{{ u.dateCreation ? u.dateCreation|date('d/m/Y') : '-' }}</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a href="{{ path('admin_user_edit', {id: u.id}) }}" class="btn btn-outline-secondary rounded-pill me-1"><i class="fas fa-edit"></i></a>
                                {% if u.email != app.user.email %}
                                    <form method="post" action="{{ path('admin_user_delete', {id: u.id}) }}" onsubmit="return confirm('Supprimer définitivement cet utilisateur ?')" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ u.id) }}">
                                        <button class="btn btn-outline-danger rounded-pill" type="submit"><i class="fas fa-trash"></i></button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="6" class="text-center py-5 text-muted">Aucun utilisateur trouvé</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    AOS.init({ duration: 800, once: true });
    const weeklyRegistrationsData = {{ weeklyRegistrations|default({'labels': [], 'data': []})|json_encode|raw }};
    const roleDistributionData = {{ roleDistribution|default({'labels': [], 'data': []})|json_encode|raw }};
    const statusDistributionData = {{ statusDistribution|default({'labels': [], 'data': []})|json_encode|raw }};
    const monthlyRegistrationsData = {{ monthlyRegistrations|default({'labels': [], 'data': []})|json_encode|raw }};

    // Graphique des inscriptions hebdomadaires (si données fournies)
    const lineCanvas = document.getElementById('activityChart');
    if (lineCanvas && weeklyRegistrationsData.labels.length > 0) {
        new Chart(lineCanvas.getContext('2d'), {
            type: 'line',
            data: {
                labels: weeklyRegistrationsData.labels,
                datasets: [{
                    label: 'Inscriptions',
                    data: weeklyRegistrationsData.data,
                    borderColor: '#4c8b3c',
                    backgroundColor: 'rgba(76,139,60,0.08)',
                    tension: 0.35,
                    fill: true,
                    pointBackgroundColor: '#1e4620',
                    pointBorderColor: '#fff',
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: '#e9ecef' } },
                    x: { grid: { display: false } }
                }
            }
        });
    } else if (lineCanvas) {
        lineCanvas.getContext('2d').fillText('Données non disponibles', 50, 50);
    }

    // Répartition des rôles
    const rolesCanvas = document.getElementById('rolesChart');
    if (rolesCanvas && roleDistributionData.labels.length > 0) {
        new Chart(rolesCanvas.getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: roleDistributionData.labels,
                datasets: [{
                    data: roleDistributionData.data,
                    backgroundColor: ['#c28b2c', '#2e7d52', '#2f89c5'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom' } },
                cutout: '66%'
            }
        });
    }

    // Statut actif/inactif
    const statusCanvas = document.getElementById('statusChart');
    if (statusCanvas && statusDistributionData.labels.length > 0) {
        new Chart(statusCanvas.getContext('2d'), {
            type: 'pie',
            data: {
                labels: statusDistributionData.labels,
                datasets: [{
                    data: statusDistributionData.data,
                    backgroundColor: ['#2e7d52', '#d97745'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom' } }
            }
        });
    }

    // Inscriptions mensuelles
    const monthlyCanvas = document.getElementById('monthlyChart');
    if (monthlyCanvas && monthlyRegistrationsData.labels.length > 0) {
        new Chart(monthlyCanvas.getContext('2d'), {
            type: 'bar',
            data: {
                labels: monthlyRegistrationsData.labels,
                datasets: [{
                    label: 'Inscriptions',
                    data: monthlyRegistrationsData.data,
                    backgroundColor: '#4c8b3c',
                    borderRadius: 10,
                    borderSkipped: false
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: '#e9ecef' } },
                    x: { grid: { display: false } }
                }
            }
        });
    }
</script>
{% endblock %}
