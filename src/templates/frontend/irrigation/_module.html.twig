<div id="irrigationModule" class="irrigation-dashboard grid grid-cols-1 xl:grid-cols-2 gap-6 p-3 md:p-6 rounded-2xl" data-endpoint="{{ path('app_irrigation_analyse') }}">
    <section class="rounded-2xl bg-white shadow-lg border border-slate-200 p-6 md:p-8">
        <div class="mb-5">
            <h3 class="text-2xl font-semibold text-slate-900 mb-1">Irrigation intelligente</h3>
            <p class="text-slate-500 text-sm mb-0">Analyse des conditions agricoles et generation automatique du plan d eau.</p>
        </div>

        <form id="irrigationForm" class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-slate-700 mb-2" for="irrigationCulture">Culture</label>
                <select id="irrigationCulture" name="culture" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" required>
                    {% for key, label in cultures %}
                        <option value="{{ key }}">{{ label }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2" for="irrigationSurface">Surface (ha)</label>
                    <input id="irrigationSurface" name="surface" type="number" step="0.1" min="0.1" value="1.0" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" required>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2" for="irrigationLocation">Ville meteo</label>
                    <input id="irrigationLocation" name="location" type="text" value="Tunis" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" required>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2" for="irrigationSoilMoisture">Humidite sol (%)</label>
                    <input id="irrigationSoilMoisture" name="soilMoisture" type="number" min="0" max="100" value="45" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" required>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2" for="irrigationLastAmount">Dernier volume (L)</label>
                    <input id="irrigationLastAmount" name="lastWaterAmount" type="number" step="1" min="0" value="800" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" required>
                </div>
            </div>

            <div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2" for="irrigationLastDate">Derniere irrigation</label>
                    <input id="irrigationLastDate" name="lastIrrigationDate" type="date" value="{{ 'now'|date_modify('-2 day')|date('Y-m-d') }}" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-emerald-500" required>
                </div>
            </div>

            <button id="irrigationSubmit" type="submit" class="w-full rounded-lg bg-gradient-to-r from-emerald-500 to-green-600 text-white font-semibold py-3 px-4 hover:from-emerald-600 hover:to-green-700 transition">Calculer le plan d irrigation</button>
            <div id="irrigationLoader" class="hidden text-sm text-slate-500">Analyse en cours...</div>
            <div id="irrigationError" class="hidden rounded-lg border border-red-300 bg-red-50 text-red-700 text-sm px-3 py-2"></div>
        </form>
    </section>

    <section class="rounded-2xl bg-white shadow-lg border border-slate-200 p-6 md:p-8">
        <div class="flex items-start justify-between mb-5">
            <div>
                <h3 class="text-2xl font-semibold text-slate-900 mb-1">Plan d irrigation optimise</h3>
                <p class="text-slate-500 text-sm mb-0">Resultat base sur meteo, sol et historique.</p>
            </div>
            <span id="irrigationUrgency" class="inline-flex px-3 py-1 rounded-full text-xs font-semibold bg-slate-100 text-slate-700">--</span>
        </div>

        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 mb-4">
            <p class="text-xs uppercase text-slate-500 mb-2">Meteo en temps reel</p>
            <p class="text-sm text-slate-700 mb-1"><strong>Lieu:</strong> <span id="irrigationWeatherLocation">--</span></p>
            <p class="text-sm text-slate-700 mb-1"><strong>Temperature:</strong> <span id="irrigationWeatherTemp">--</span></p>
            <p class="text-sm text-slate-700 mb-1"><strong>Humidite:</strong> <span id="irrigationWeatherHumidity">--</span></p>
            <p class="text-sm text-slate-700 mb-1"><strong>Condition:</strong> <span id="irrigationWeatherDesc">--</span></p>
        </div>

        <div class="grid grid-cols-2 gap-3 mb-5">
            <div class="rounded-xl border border-slate-200 p-4 bg-blue-50">
                <p class="text-xs uppercase text-slate-500 mb-1">Eau recommandee</p>
                <p class="text-2xl font-bold text-blue-700"><span id="irrigationWater">--</span> L</p>
            </div>
            <div class="rounded-xl border border-slate-200 p-4 bg-emerald-50">
                <p class="text-xs uppercase text-slate-500 mb-1">Duree estimee</p>
                <p class="text-2xl font-bold text-emerald-700"><span id="irrigationDuration">--</span> min</p>
            </div>
            <div class="rounded-xl border border-slate-200 p-4">
                <p class="text-xs uppercase text-slate-500 mb-1">Heure conseillee</p>
                <p class="text-xl font-semibold text-slate-900" id="irrigationTime">--</p>
            </div>
            <div class="rounded-xl border border-slate-200 p-4">
                <p class="text-xs uppercase text-slate-500 mb-1">Date conseillee</p>
                <p class="text-xl font-semibold text-slate-900" id="irrigationDate">--</p>
            </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-4 mb-4">
            <p class="text-xs uppercase text-slate-500 mb-2">Score urgence</p>
            <div class="flex items-center justify-between">
                <p class="text-2xl font-bold text-slate-900"><span id="irrigationUrgencyScore">0</span>/100</p>
                <span id="irrigationUrgencyCategory" class="text-sm font-semibold text-slate-700">faible</span>
            </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
            <p class="text-xs uppercase text-slate-500 mb-2">Justification</p>
            <p class="text-sm text-slate-700 mb-0" id="irrigationJustification">Remplissez le formulaire pour generer un plan intelligent.</p>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-4 mt-4">
            <p class="text-xs uppercase text-slate-500 mb-2">Recommandations</p>
            <ul id="irrigationRecommendations" class="text-sm text-slate-700 mb-0 list-disc ps-4">
                <li>Les recommandations dynamiques apparaitront ici.</li>
            </ul>
        </div>
    </section>
</div>
