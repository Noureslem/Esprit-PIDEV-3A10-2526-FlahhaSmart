{% extends 'base.html.twig' %}

{% block title %}{{ 'equipement.new.title'|trans }}{% endblock %}
{% block navbar_title %}{{ 'equipement.new.navbar_title'|trans }}{% endblock %}

{% block body %}
    <div class="page-header">
        <h1 class="page-title">
            <i class="bi bi-plus-circle me-2"></i>{{ 'equipement.new.title'|trans }}
        </h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">{{ 'common.home'|trans }}</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_equipement_index') }}">{{ 'nav.equipements'|trans }}</a></li>
                <li class="breadcrumb-item active">{{ 'common.new'|trans }}</li>
            </ol>
        </nav>
    </div>

    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card mx-auto">
                <div class="card-header">
                    <i class="bi bi-box-seam me-2"></i>{{ 'equipement.new.card_header'|trans }}
                </div>
                <div class="card-body">
                    {{ include('frontend/equipement/_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
