{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}

    {# Global form errors #}
    {% if form.vars.errors|length > 0 %}
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>{{ 'common.error'|trans }} :</strong> {{ 'common.please_fix_errors'|trans }}
        {{ form_errors(form) }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ 'common.close'|trans }}"></button>
    </div>
    {% endif %}

    <div class="row">
        <div class="col-md-6 mb-3">
            {{ form_label(form.type_operation, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
            {{ form_widget(form.type_operation, {
                'attr': {
                    'class': 'form-control ' ~ (form.type_operation.vars.errors|length ? 'is-invalid' : ''),
                    'placeholder': form.type_operation.vars.attr.placeholder|default('')|trans
                }
            }) }}
            {% if form.type_operation.vars.errors|length %}
            <div class="invalid-feedback d-block">
                {{ form_errors(form.type_operation) }}
            </div>
            {% endif %}
        </div>
    </div>
    
    <div class="row">
        <div class="col-md-6 mb-3">
            {{ form_label(form.date_debut, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
            {{ form_widget(form.date_debut, {
                'attr': {
                    'class': 'form-control js-flatpickr ' ~ (form.date_debut.vars.errors|length ? 'is-invalid' : '')
                }
            }) }}
            {% if form.date_debut.vars.errors|length %}
            <div class="invalid-feedback d-block">
                {{ form_errors(form.date_debut) }}
            </div>
            {% endif %}
        </div>
        
        <div class="col-md-6 mb-3">
            {{ form_label(form.date_fin, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
            {{ form_widget(form.date_fin, {
                'attr': {
                    'class': 'form-control js-flatpickr ' ~ (form.date_fin.vars.errors|length ? 'is-invalid' : '')
                }
            }) }}
            {% if form.date_fin.vars.errors|length %}
            <div class="invalid-feedback d-block">
                {{ form_errors(form.date_fin) }}
            </div>
            {% endif %}
        </div>
    </div>
    
    <div class="row">
        <div class="col-md-6 mb-3">
            {{ form_label(form.equipement, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
            {{ form_widget(form.equipement, {
                'attr': {
                    'class': 'form-select ' ~ (form.equipement.vars.errors|length ? 'is-invalid' : '')
                }
            }) }}
            {% if form.equipement.vars.errors|length %}
            <div class="invalid-feedback d-block">
                {{ form_errors(form.equipement) }}
            </div>
            {% endif %}
        </div>
    </div>
    
    {{ form_rest(form) }}
    
    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary px-4 py-2">
            <i class="bi bi-check-lg me-1"></i>
            {{ button_label|default('common.save'|trans) }}
        </button>
        {% if cancel_drawer|default(false) %}
            <button type="button" class="btn btn-outline-secondary px-4 py-2" data-action="right-drawer#close">
                <i class="bi bi-x-lg me-1"></i>
                {{ 'common.cancel'|trans }}
            </button>
        {% else %}
            <a href="{{ path('app_operation_index') }}" class="btn btn-outline-secondary px-4 py-2">
                <i class="bi bi-x-lg me-1"></i>
                {{ 'common.cancel'|trans }}
            </a>
        {% endif %}
    </div>
{{ form_end(form) }}
