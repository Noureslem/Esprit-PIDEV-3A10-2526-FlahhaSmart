{% extends 'frontend/base.html.twig' %}

{% block title %}{{ 'operation.index.title'|trans }}{% endblock %}
{% block navbar_title %}{{ 'operation.index.navbar_title'|trans }}{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <style>
        .export-modal-content {
            border: 0;
            border-radius: 1rem;
            box-shadow: 0 28px 60px rgba(15, 23, 42, 0.25);
        }

        .export-card {
            border: 1px solid #e2e8f0;
            border-radius: 0.9rem;
            background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
            padding: 1rem;
        }

        .export-option {
            border: 1px solid #dbe2ea;
            border-radius: 0.75rem;
            padding: 0.6rem 0.75rem;
            background: #ffffff;
            transition: all 0.2s ease;
        }

        .export-option:hover {
            border-color: #0f766e;
            box-shadow: 0 6px 18px rgba(15, 118, 110, 0.1);
            transform: translateY(-1px);
        }

        .export-option .form-check-input {
            margin-top: 0.25rem;
            margin-right: 0.5rem;
        }

        .export-option .form-check-label {
            font-weight: 600;
            color: #0f172a;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="page-header d-flex justify-content-between align-items-center">
        <div>
            <h1 class="page-title">
                <i class="bi bi-clipboard-check me-2"></i>{{ 'operation.index.title'|trans }}
            </h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="#">{{ 'common.home'|trans }}</a></li>
                    <li class="breadcrumb-item active">{{ 'nav.operations'|trans }}</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <button type="button"
                    class="btn btn-outline-dark"
                    data-bs-toggle="modal"
                    data-bs-target="#operationExportModal">
                <i class="bi bi-file-earmark-pdf me-1"></i>
                {{ 'operation.export.open_modal'|trans }}
            </button>
            <button type="submit"
                    class="btn btn-danger"
                    form="operation-bulk-delete-form"
                    data-bulk-delete-trigger
                    data-confirm-message="{{ 'operation.bulk.confirm'|trans }}">
                <i class="bi bi-trash me-1"></i>
                {{ 'app.actions.delete_selection'|trans }}
            </button>
            <a href="{{ path('app_operation_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>
                {{ 'app.actions.new_operation'|trans }}
            </a>
        </div>
    </div>

    {# Search and Filter Form #}
    <div class="search-filter-section mb-4 p-3 bg-light rounded border">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label for="filterType" class="form-label">{{ 'operation.index.filter.type_label'|trans }}</label>
                <input type="text" 
                       id="filterType" 
                       name="type" 
                       class="form-control" 
                       placeholder="{{ 'operation.index.filter.type_placeholder'|trans }}"
                       value="{{ filters.type ?? '' }}">
            </div>
            <div class="col-md-4">
                <label for="filterStatut" class="form-label">{{ 'operation.index.filter.status_label'|trans }}</label>
                <select id="filterStatut" name="statut" class="form-select">
                    <option value="">{{ 'operation.index.filter.status_all'|trans }}</option>
                    {% for statut in statuts %}
                        <option value="{{ statut }}" 
                                {% if filters.statut == statut %}selected{% endif %}>
                            {{ statut }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-4 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">
                    <i class="bi bi-search me-1"></i>{{ 'common.search'|trans }}
                </button>
                <a href="{{ path('app_operation_index') }}" class="btn btn-secondary">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>{{ 'common.reset'|trans }}
                </a>
            </div>
        </form>
    </div>

    <div class="modal fade" id="operationExportModal" tabindex="-1" aria-labelledby="operationExportModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content export-modal-content">
                <div class="modal-header border-0 pb-0">
                    <div>
                        <h5 class="modal-title" id="operationExportModalLabel">{{ 'operation.export.modal_title'|trans }}</h5>
                        <p class="text-muted mb-0 small">{{ 'operation.export.modal_subtitle'|trans }}</p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'common.close'|trans }}"></button>
                </div>
                <div class="modal-body">
                    <div class="export-card">
                        {{ form_start(exportForm, {'attr': {'id': 'operation-export-form'}}) }}

                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <button type="button" class="btn btn-sm btn-outline-secondary js-export-toggle" data-export-toggle="all">
                                {{ 'operation.export.select_all'|trans }}
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary js-export-toggle" data-export-toggle="none">
                                {{ 'operation.export.deselect_all'|trans }}
                            </button>
                        </div>

                        <div class="row g-2">
                            {% for columnField in exportForm.columns %}
                                <div class="col-md-6">
                                    <div class="form-check export-option">
                                        {{ form_widget(columnField, {'attr': {'class': 'form-check-input js-export-column'}}) }}
                                        {{ form_label(columnField, null, {'label_attr': {'class': 'form-check-label'}}) }}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>

                        {{ form_rest(exportForm) }}

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                                {{ 'common.cancel'|trans }}
                            </button>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-file-earmark-pdf me-1"></i>
                                {{ 'operation.export.submit'|trans }}
                            </button>
                        </div>

                        {{ form_end(exportForm, {'render_rest': false}) }}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="table-container">
        {# Keep bulk form separate to avoid invalid nested forms inside table rows #}
        <form id="operation-bulk-delete-form"
              method="post"
              action="{{ path('app_operation_bulk_delete') }}"
              data-bulk-form>
            <input type="hidden" name="_token" value="{{ csrf_token('bulk_delete_operation') }}">
        </form>

        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th scope="col" style="width: 40px;">
                            <input type="checkbox"
                                   class="form-check-input js-bulk-select-all"
                                   data-bulk-form-id="operation-bulk-delete-form"
                                   aria-label="{{ 'common.select_all'|trans }}">
                        </th>
                        <th scope="col">
                            {{ 'operation.index.table.type'|trans }}
                            <span class="sort-links">
                                <a href="{{ path('app_operation_index', filters|merge({'sort': 'type_operation', 'direction': 'ASC'})) }}" 
                                   title="{{ 'common.sort.asc'|trans }}" class="sort-link">▲</a>
                                <a href="{{ path('app_operation_index', filters|merge({'sort': 'type_operation', 'direction': 'DESC'})) }}" 
                                   title="{{ 'common.sort.desc'|trans }}" class="sort-link">▼</a>
                            </span>
                        </th>
                        <th scope="col">{{ 'operation.index.table.equipment'|trans }}</th>
                        <th scope="col">
                            {{ 'operation.index.table.start_date'|trans }}
                            <span class="sort-links">
                                <a href="{{ path('app_operation_index', filters|merge({'sort': 'date_debut', 'direction': 'ASC'})) }}" 
                                   title="{{ 'common.sort.asc'|trans }}" class="sort-link">▲</a>
                                <a href="{{ path('app_operation_index', filters|merge({'sort': 'date_debut', 'direction': 'DESC'})) }}" 
                                   title="{{ 'common.sort.desc'|trans }}" class="sort-link">▼</a>
                            </span>
                        </th>
                        <th scope="col">
                            {{ 'operation.index.table.end_date'|trans }}
                            <span class="sort-links">
                                <a href="{{ path('app_operation_index', filters|merge({'sort': 'date_fin', 'direction': 'ASC'})) }}" 
                                   title="{{ 'common.sort.asc'|trans }}" class="sort-link">▲</a>
                                <a href="{{ path('app_operation_index', filters|merge({'sort': 'date_fin', 'direction': 'DESC'})) }}" 
                                   title="{{ 'common.sort.desc'|trans }}" class="sort-link">▼</a>
                            </span>
                        </th>
                        <th scope="col">{{ 'operation.index.table.status'|trans }}</th>
                        <th scope="col" class="text-end">{{ 'common.actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                {% for operation in operations %}
                    <tr>
                        <td>
                            <input type="checkbox"
                                   class="form-check-input js-bulk-item"
                                   form="operation-bulk-delete-form"
                                   name="ids[]"
                                   value="{{ operation.id }}"
                                aria-label="{{ 'operation.bulk.item_aria'|trans({'%id%': operation.id}) }}">
                        </td>
                        <td>
                            <strong>{{ operation.typeOperation }}</strong>
                        </td>
                         <td>
                            <i class="bi bi-tools me-1 text-muted"></i>
                            {{ operation.equipement ? operation.equipement.nom : '-' }}
                        </td>
                        <td>
                            <i class="bi bi-calendar-event me-1 text-muted"></i>
                            {{ operation.dateDebut ? operation.dateDebut|date('d/m/Y') : '-' }}
                        </td>
                        <td>
                            <i class="bi bi-calendar-check me-1 text-muted"></i>
                            {{ operation.dateFin ? operation.dateFin|date('d/m/Y') : '-' }}
                        </td>
                        <td>
                            <span class="badge badge-status-{{ operation.statut|lower|replace({' ': '_', 'é': 'e'}) }}">
                                {{ operation.statut }}
                            </span>
                        </td>
                        <td>
                            <div class="btn-group-actions justify-content-end">
                                <a href="{{ path('app_operation_edit', {'id': operation.id}) }}" 
                                   class="btn btn-outline-warning btn-action" title="{{ 'common.update'|trans }}">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('app_operation_delete', {'id': operation.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ operation.id) }}">
                                    <button type="button" class="btn btn-outline-danger btn-action delete-btn" title="{{ 'common.delete'|trans }}">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="bi bi-inbox d-block"></i>
                                <p class="mb-3">{{ 'operation.index.empty'|trans }}</p>
                                <a href="{{ path('app_operation_new') }}" class="btn btn-primary btn-sm">
                                    <i class="bi bi-plus-lg me-1"></i>
                                    {{ 'operation.index.empty_cta'|trans }}
                                </a>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
                </table>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modal = document.getElementById('operationExportModal');
            if (!modal) {
                return;
            }

            const getCheckboxes = function () {
                return Array.from(modal.querySelectorAll('.js-export-column'));
            };

            modal.querySelectorAll('.js-export-toggle').forEach(function (button) {
                button.addEventListener('click', function () {
                    const target = button.getAttribute('data-export-toggle');
                    const shouldCheck = target === 'all';

                    getCheckboxes().forEach(function (checkbox) {
                        checkbox.checked = shouldCheck;
                    });
                });
            });
        });
    </script>
{% endblock %}
