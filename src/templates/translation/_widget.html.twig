{#
  Usage:
  - Include this partial where you need a dynamic translation UI:
      {% include 'translation/_widget.html.twig' %}
  - And include the JS on that page:
      {% block javascripts %}
          <script src="{{ asset('js/azure-translate-widget.js') }}" defer></script>
      {% endblock %}
#}

<div class="card"
     data-translate-widget
     data-translate-endpoint="{{ path('app_api_translate') }}"
     data-csrf-token="{{ csrf_token('ajax_translate') }}">
    <div class="card-body">
        <h5 class="card-title mb-3">{{ 'translation.widget.title'|trans }}</h5>

        <div class="mb-3">
            <label class="form-label">{{ 'translation.widget.source_text'|trans }}</label>
            <textarea class="form-control" rows="3" data-translate-source></textarea>
        </div>

        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label">{{ 'translation.widget.to_label'|trans }}</label>
                <select class="form-select" data-translate-to>
                    <option value="en">{{ 'translation.lang.en'|trans }}</option>
                    <option value="fr">{{ 'translation.lang.fr'|trans }}</option>
                    <option value="ar">{{ 'translation.lang.ar'|trans }}</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">{{ 'translation.widget.from_label'|trans }}</label>
                <select class="form-select" data-translate-from>
                    <option value="">{{ 'translation.widget.auto'|trans }}</option>
                    <option value="fr">{{ 'translation.lang.fr'|trans }}</option>
                    <option value="en">{{ 'translation.lang.en'|trans }}</option>
                    <option value="ar">{{ 'translation.lang.ar'|trans }}</option>
                </select>
            </div>
            <div class="col-md-4">
                <button type="button" class="btn btn-primary w-100" data-translate-submit>
                    {{ 'translation.widget.submit'|trans }}
                </button>
            </div>
        </div>

        <hr class="my-3">

        <div>
            <label class="form-label">{{ 'translation.widget.result'|trans }}</label>
            <div class="form-control" style="min-height: 3rem;" data-translate-result></div>
        </div>
    </div>
</div>
