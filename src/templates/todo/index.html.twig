{% extends 'base.html.twig' %}

{% block title %}Todo List - FlahaSmart{% endblock %}

{% block body %}
<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">
            <i class="bi bi-check2-square me-2"></i> Liste des tâches
        </h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">{{ 'common.home'|trans|default('Accueil') }}</a></li>
                <li class="breadcrumb-item active">Todos</li>
            </ol>
        </nav>
    </div>
    <div>
        <a href="{{ path('app_todo_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Ajouter une tâche
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header bg-white">
        <i class="bi bi-table me-2"></i> Toutes les tâches
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Consultant</th>
                        <th>Tâche</th>
                        <th>Statut</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for todo in todos %}
                    <tr>
                        <td><strong>{{ todo.nomTache }}</strong></td>
                        <td>{{ todo.tache }}</td>
                        <td>
                            <span class="badge 
                                {% if todo.statut == 'TODO' %}bg-warning text-dark
                                {% elseif todo.statut == 'DOING' %}bg-info text-dark
                                {% else %}bg-success
                                {% endif %}">
                                {{ todo.statut }}
                            </span>
                        </td>
                        <td class="text-end">
                            <div class="d-flex gap-2 justify-content-end">
                                <a href="{{ path('app_todo_edit', {nomTache: todo.nomTache, tache: todo.tache}) }}" class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil me-1"></i> Modifier
                                </a>
                                <form method="post" action="{{ path('app_todo_delete', {nomTache: todo.nomTache, tache: todo.tache}) }}" onsubmit="return confirm('Supprimer cette tâche ?');" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ todo.nomTache ~ todo.tache) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash3 me-1"></i> Supprimer
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="4" class="text-center py-4">
                            <i class="bi bi-inbox fs-2 text-muted d-block mb-2"></i>
                            Aucune tâche trouvée
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}