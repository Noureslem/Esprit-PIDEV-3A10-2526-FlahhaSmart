{% extends 'base.html.twig' %}

{% block title %}Identifier une plante - Agriculteur{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-6 mx-auto">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-success text-white rounded-4 rounded-bottom-0">
                    <h2 class="h4 mb-0">
                        <i class="fa-solid fa-leaf me-2"></i>Identifier une plante
                    </h2>
                </div>
                <div class="card-body p-4">
                    <a href="{{ path('agriculteur_stock_index') }}" class="btn btn-sm btn-outline-secondary mb-3">
                        <i class="fa-solid fa-arrow-left me-1"></i>Retour aux stocks
                    </a>

                    {% if error %}
                        <div class="alert alert-danger">{{ error }}</div>
                    {% endif %}

                    <form method="post" enctype="multipart/form-data" id="identifyForm">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                <i class="fa-solid fa-camera me-1"></i>Photo de la plante
                            </label>
                            <input type="file" name="image" id="imageInput" class="form-control" accept="image/*" capture="environment" required>
                            <small class="text-muted">Prenez une photo ou sélectionnez une image (JPG/PNG, max 10MB)</small>
                        </div>

                        <div id="previewContainer" class="mb-3 text-center d-none">
                            <img id="imagePreview" class="img-fluid rounded-3" style="max-height: 200px;">
                        </div>

                        <button type="submit" class="btn btn-success w-100 py-2 rounded-3" id="submitBtn">
                            <i class="fa-solid fa-search me-2"></i>Identifier
                        </button>
                    </form>

                    <div id="loadingIndicator" class="text-center d-none mt-3">
                        <div class="spinner-border text-success" role="status">
                            <span class="visually-hidden">Chargement...</span>
                        </div>
                        <p class="mt-2 text-muted">Identification en cours...</p>
                    </div>

                    {% if result is defined and result and result.results is defined %}
                    <div class="mt-4">
                        <hr>
                        <h5 class="text-success fw-bold">🌿 Résultats de l'identification</h5>
                        
                        {% if result.results|length > 0 %}
                            {% set plant = result.results[0] %}
                            <div class="card border-success mt-3">
                                <div class="card-body">
                                    <h4 class="card-title text-success fw-bold">
                                        {{ plant.species.commonNames[0] ?? plant.species.scientificNameWithoutAuthor }}
                                    </h4>
                                    <p class="text-muted small">
                                        <strong>Nom scientifique :</strong> {{ plant.species.scientificNameWithoutAuthor }}
                                    </p>
                                    
                                    <div class="mt-3">
                                        <strong>Score de correspondance :</strong>
                                        <div class="progress mb-2" style="height: 8px;">
                                            <div class="progress-bar bg-success" style="width: {{ (plant.score * 100)|round }}%"></div>
                                        </div>
                                        <span class="badge bg-success">{{ (plant.score * 100)|round }}%</span>
                                    </div>

                                    {% if plant.species.commonNames|length > 0 %}
                                    <div class="mt-3">
                                        <strong><i class="fa-solid fa-tag me-1"></i>Noms communs :</strong>
                                        <p class="mb-0">{{ plant.species.commonNames|join(', ') }}</p>
                                    </div>
                                    {% endif %}

                                    {% if plant.species.family is defined %}
                                    <div class="mt-3">
                                        <strong><i class="fa-solid fa-tree me-1"></i>Famille :</strong>
                                        <p class="mb-0">{{ plant.species.family.scientificNameWithoutAuthor ?? plant.species.family.commonName ?? 'Non spécifié' }}</p>
                                    </div>
                                    {% endif %}

                                    {% if plant.images|length > 0 %}
                                    <div class="mt-3">
                                        <strong><i class="fa-solid fa-image me-1"></i>Images similaires :</strong>
                                        <div class="row mt-2">
                                            {% for img in plant.images|slice(0,2) %}
                                            <div class="col-6">
                                                <img src="{{ img.url.m }}" class="img-fluid rounded-3" style="max-height: 100px; width: 100%; object-fit: cover;">
                                            </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                    {% endif %}
                                </div>
                            </div>
                            
                            <!-- Bouton pour ajouter au stock -->
                            <div class="mt-3 text-center">
                                <button type="button" class="btn btn-outline-success" onclick="addToStock('{{ plant.species.commonNames[0] ?? plant.species.scientificNameWithoutAuthor }}')">
                                    <i class="fa-solid fa-plus me-1"></i>Ajouter cette plante à mon stock
                                </button>
                            </div>
                            
                            <script>
                            function addToStock(plantName) {
                                // Remplir automatiquement le formulaire d'ajout de stock
                                if (confirm('Ajouter "' + plantName + '" à votre stock ?')) {
                                    window.location.href = '{{ path("agriculteur_stock_new") }}?type=' + encodeURIComponent(plantName);
                                }
                            }
                            </script>
                        {% else %}
                            <div class="alert alert-info">Aucune plante identifiée. Essayez avec une autre photo.</div>
                        {% endif %}
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('imageInput').addEventListener('change', function(e) {
    const file = e.target.files[0];
    const previewContainer = document.getElementById('previewContainer');
    const preview = document.getElementById('imagePreview');
    
    if (file) {
        if (file.size > 10 * 1024 * 1024) {
            alert('L\'image est trop volumineuse (max 10MB)');
            this.value = '';
            previewContainer.classList.add('d-none');
            return;
        }
        
        const reader = new FileReader();
        reader.onload = function(event) {
            preview.src = event.target.result;
            previewContainer.classList.remove('d-none');
        };
        reader.readAsDataURL(file);
    }
});

document.getElementById('identifyForm').addEventListener('submit', function() {
    document.getElementById('loadingIndicator').classList.remove('d-none');
    document.getElementById('submitBtn').disabled = true;
});
</script>
{% endblock %}