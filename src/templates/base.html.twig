            </a>
        {% else %}
            <span class="nav-section">Client</span>
            <a class="nav-link {% if app.request.attributes.get('_route') == 'dashboard_client' %}active{% endif %}"
               href="{{ path('dashboard_client') }}">
                <i class="bi bi-house"></i> Accueil
            </a>
            <a class="nav-link" href="#">
                <i class="bi bi-bag"></i> Mes commandes
            </a>
                    </a><li class="nav-item"><a class="nav-link" href="{{ path('client_produit_index') }}"> <i class="fa-solid fa-leaf me-1"></i>Nos Produits</a></li>

        {% endif %}

        <span class="nav-section">Compte</span>
        <a class="nav-link" href="#">
     <a class="nav-link {% if app.request.attributes.get('_route') == 'app_profile' %}active{% endif %}" 
   href="{{ path('app_profile') }}">
    <i class="bi bi-person-gear"></i> Profil
</a>

        <a class="nav-link text-danger" href="{{ path('app_logout') }}">
            <i class="bi bi-box-arrow-right"></i> Déconnexion
        </a>
    </nav>
</div>
{% endif %}

{# CONTENEUR PRINCIPAL #}
<div class="{% if app.user %}main{% else %}container py-5{% endif %}">
    {% if app.user %}
    <div class="topbar">
        <div>
            <strong>{% block page_title %}Tableau de bord{% endblock %}</strong>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="lang-switch-group" role="group" aria-label="Language switch" data-no-auto-translate>
                {% for locale, label in {'fr': 'FR', 'en': 'EN', 'ar': 'AR'} %}
                    <a class="lang-chip {% if currentLocale starts with locale %}active{% endif %}" href="{{ path('app_locale_switch', {'_locale': locale}) }}" title="{{ locale|upper }}">
                        {{ label }}
                    </a>
                {% endfor %}
            </div>
            <span class="text-muted small">{{ "now"|date("d/m/Y H:i") }}</span>
            <span class="badge bg-secondary">{{ app.user.role }}</span>
        </div>
    </div>
    {% else %}
    <div class="d-flex justify-content-end mb-3">
        <div class="lang-switch-group" role="group" aria-label="Language switch" data-no-auto-translate>
            {% for locale, label in {'fr': 'FR', 'en': 'EN', 'ar': 'AR'} %}
                <a class="lang-chip {% if currentLocale starts with locale %}active{% endif %}" href="{{ path('app_locale_switch', {'_locale': locale}) }}" title="{{ locale|upper }}">
                    {{ label }}
                </a>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content confirm-modal">
            <div class="modal-header">
                <div class="d-flex align-items-center gap-2">
                    <span class="confirm-modal__icon">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </span>
                    <h5 class="modal-title" id="deleteModalLabel">Confirmer la suppression</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'common.cancel'|trans }}"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">{{ 'common.confirm_delete.message'|trans }}</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-confirm-cancel data-bs-dismiss="modal">{{ 'common.cancel'|trans }}</button>
                <button type="button" class="btn btn-danger" id="confirmDelete">
                    <i class="bi bi-trash me-1"></i>{{ 'common.delete'|trans }}
                </button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>



    <!-- Chatbot Widget -->
    {% include 'components/chatbot.html.twig' %}
    
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Flatpickr JS -->
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <!-- Bulk selection (no build step) -->
    <script src="{{ asset('js/bulk-selection.js') }}" defer></script>
    <!-- Global page auto-translation for hardcoded labels -->
    <script src="{{ asset('js/page-auto-translate.js') }}" defer></script>
    <!-- Chatbot Widget -->
    <script src="{{ asset('js/chatbot-widget.js') }}" defer></script>
    
    <script>
        // Sidebar Toggle
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('show');
        }

        const i18nOk = {{ 'common.ok'|trans|json_encode|raw }};
        const i18nCancel = {{ 'common.cancel'|trans|json_encode|raw }};
        const i18nSingleDeleteMessage = {{ 'common.confirm_delete.message'|trans|json_encode|raw }};

        // Reusable Bootstrap confirmation modal (single delete + bulk delete)
        (function () {
            const modalEl = document.getElementById('deleteModal');
            const canUseBootstrapModal = !!modalEl && typeof bootstrap !== 'undefined';

            const modal = canUseBootstrapModal ? new bootstrap.Modal(modalEl) : null;
            const bodyEl = canUseBootstrapModal ? modalEl.querySelector('.modal-body') : null;
            const cancelBtn = canUseBootstrapModal ? modalEl.querySelector('[data-confirm-cancel]') : null;
            const confirmBtn = canUseBootstrapModal ? document.getElementById('confirmDelete') : null;

            let onConfirm = null;

            function setMessage(message) {
                if (!bodyEl) return;
                const p = bodyEl.querySelector('p');
                if (p) {
                    p.textContent = message;
                } else {
                    bodyEl.textContent = message;
                }
            }

            function openInfo(message) {
                if (!canUseBootstrapModal) {
                    window.alert(message);
                    return;
                }

                setMessage(message);
                if (confirmBtn) confirmBtn.classList.add('d-none');
                if (cancelBtn) cancelBtn.textContent = i18nOk;
                onConfirm = null;
                modal?.show();
            }

            function openConfirm(message, callback) {
                if (!canUseBootstrapModal) {
                    if (window.confirm(message) && typeof callback === 'function') {
                        callback();
                    }
                    return;
                }

                setMessage(message);
                if (confirmBtn) confirmBtn.classList.remove('d-none');
                if (cancelBtn) cancelBtn.textContent = i18nCancel;
                onConfirm = callback;
                modal?.show();
            }

            confirmBtn?.addEventListener('click', function () {
                if (typeof onConfirm === 'function') {
                    modal?.hide();
                    onConfirm();
                }
            });

            // Single delete buttons
            document.addEventListener('click', function (e) {
                const btn = e.target.closest('.delete-btn');
                if (!btn) return;

                e.preventDefault();
                const form = btn.closest('form');
                if (!form) return;

                openConfirm(i18nSingleDeleteMessage, function () {
                    form.submit();
                });
            });

            // Expose helpers for other scripts (bulk selection)
            window.AppConfirmModal = {
                info: openInfo,
                confirm: openConfirm,
            };
        })();

        // Simple i18n strings for standalone JS files
        window.AppI18n = Object.assign(window.AppI18n || {}, {
            emptySelectionMessage: {{ 'common.bulk_select_at_least_one'|trans|json_encode|raw }},
            bulkConfirmCountMessage: {{ 'common.confirm_bulk_delete_count'|trans|json_encode|raw }},
        });
        
        // Auto-hide alerts after 5 seconds
        setTimeout(() => {
            document.querySelectorAll('.alert').forEach(alert => {
                new bootstrap.Alert(alert).close();
            });
        }, 5000);

        // Initialize Flatpickr for all inputs with .js-flatpickr
        document.addEventListener('DOMContentLoaded', function () {
            if (typeof flatpickr !== 'undefined') {
                document.querySelectorAll('.js-flatpickr').forEach(function(el) {
                    flatpickr(el, {
                        dateFormat: 'Y-m-d',
                        altInput: true,
                        altFormat: 'd/m/Y',
                        allowInput: true,
                        disableMobile: true
                    });
                });
            }
        });

    </script>
    
    {% block javascripts %}{% endblock %}

</body>
</html>