            <a class="nav-link" href="{{ path('app_equipement_index') }}">
                <i class="bi bi-tools"></i> Équipements
            </a>
    
            <a class="nav-link {% if app.request.attributes.get('_route') starts  with 'workspace' %}active{% endif %}" 
              href="{{ path('app_workspace_index') }}"> <i class="bi bi-kanban"></i> Workspace </a>

            <a class="nav-link" href="{{ path('agriculteur_consommation_index') }}">
                <i class="bi bi-box-seam"></i> Consommations
            </a>
            <a class="nav-link" href="#">
