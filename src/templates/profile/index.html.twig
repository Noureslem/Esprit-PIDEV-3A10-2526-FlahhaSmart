{# templates/profile/index.html.twig #}
{% extends 'base.html.twig' %}
{% block title %}{{ 'profile.title'|trans }}{% endblock %}
{% block page_title %}{{ 'profile.title'|trans }}{% endblock %}

{% block body %}
<div class="row g-4">

    {# ── Carte infos gauche ── #}
    <div class="col-lg-4">
        <div class="card p-4 text-center">
            <div style="font-size:4rem;">👤</div>
            <h4 class="fw-bold mt-2">{{ user.fullName }}</h4>
            <p class="text-muted mb-1">{{ user.email }}</p>
            <span class="badge badge-{{ user.role }} fs-6 px-3 py-2">{{ user.role }}</span>

            <hr>

            <div class="text-start">
                <div class="mb-2">
                    <small class="text-muted d-block">{{ 'profile.field.telephone'|trans }}</small>
                    <strong>{{ user.telephone ?? ('common.not_available'|trans) }}</strong>
                </div>
                <div class="mb-2">
                    <small class="text-muted d-block">{{ 'profile.field.ville'|trans }}</small>
                    <strong>{{ user.ville ?? ('common.not_available'|trans) }}</strong>
                </div>
                <div class="mb-2">
                    <small class="text-muted d-block">{{ 'profile.field.member_since'|trans }}</small>
                    <strong>{{ user.dateCreation|date('d/m/Y') }}</strong>
                </div>
                <div>
                    <small class="text-muted d-block">{{ 'profile.field.status'|trans }}</small>
                    {% if user.actif %}
                        <span class="badge bg-success">{{ 'common.active'|trans }}</span>
                    {% else %}
                        <span class="badge bg-danger">{{ 'common.inactive'|trans }}</span>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {# ── Formulaire modification droite ── #}
    <div class="col-lg-8">
        <div class="card p-4">
            <h5 class="fw-bold mb-4">✏️ {{ 'profile.edit.heading'|trans }}</h5>

            {{ form_start(form) }}

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">{{ form_label(form.nom) }}</label>
                    {{ form_widget(form.nom) }}
                    {{ form_errors(form.nom) }}
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">{{ form_label(form.prenom) }}</label>
                    {{ form_widget(form.prenom) }}
                </div>
            </div>

            <div class="mt-3">
                <label class="form-label fw-semibold">{{ form_label(form.email) }}</label>
                {{ form_widget(form.email) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="row g-3 mt-1">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">{{ form_label(form.telephone) }}</label>
                    {{ form_widget(form.telephone) }}
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">{{ form_label(form.ville) }}</label>
                    {{ form_widget(form.ville) }}
                </div>
            </div>

            {# PAS DE CHAMP ADRESSE ICI #}

            <hr class="my-4">
            <h6 class="fw-bold mb-3">🔒 {{ 'profile.password.heading'|trans }}</h6>
            <div class="mb-3">
                <label class="form-label fw-semibold">{{ form_label(form.newPassword.first) }}</label>
                {{ form_widget(form.newPassword.first) }}
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">{{ form_label(form.newPassword.second) }}</label>
                {{ form_widget(form.newPassword.second) }}
                {{ form_errors(form.newPassword) }}
            </div>
            <small class="text-muted">{{ 'profile.password.keep_current_hint'|trans }}</small>

            <div class="mt-4">
                <button type="submit" class="btn btn-success px-4 py-2 fw-semibold">
                    <i class="bi bi-check-circle"></i> {{ 'profile.edit.submit'|trans }}
                </button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>

</div>
{% endblock %}