{% extends 'admin/base_admin.html.twig' %}

{% block title %}Modifier le Thread - Admin{% endblock %}

{% block admin_body %}
    <div class="panel-header">
        <div class="panel-title">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
            Modifier le Thread #{{ thread.idThread }}
        </div>
        <a href="{{ path('forum_admin_threads') }}" class="btn btn-secondary" style="background: rgba(0,0,0,0.05); color: var(--text-muted);">Retour</a>
    </div>

    <div class="panel" style="max-width: 800px; margin: 0 auto;">
        <form method="post" action="{{ path('forum_admin_threads', {id: thread.idThread}) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('edit' ~ thread.idThread) }}">
            
            <div style="margin-bottom: 1.5rem;">
                <label for="titre" style="display: block; margin-bottom: 0.5rem; color: var(--text-main); font-weight: 600;">Titre du Thread</label>
                <input type="text" id="titre" name="titre" value="{{ thread.titre }}" required style="width: 100%; padding: 0.75rem; border: 1px solid var(--border-color); border-radius: 0.5rem; font-family: var(--font-sans);">
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label for="contenu" style="display: block; margin-bottom: 0.5rem; color: var(--text-main); font-weight: 600;">Contenu</label>
                <textarea id="contenu" name="contenu" rows="8" required style="width: 100%; padding: 0.75rem; border: 1px solid var(--border-color); border-radius: 0.5rem; font-family: var(--font-sans); resize: vertical;">{{ thread.contenu }}</textarea>
            </div>

            <div style="display: flex; justify-content: flex-end;">
                <button type="submit" class="btn btn-primary" style="padding: 0.75rem 1.5rem; font-size: 1rem;">
                    Enregistrer les modifications
                </button>
            </div>
        </form>
    </div>
{% endblock %}
