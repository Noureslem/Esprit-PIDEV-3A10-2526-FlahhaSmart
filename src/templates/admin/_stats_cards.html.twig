<div class="row g-4 mb-5">
    <div class="col-md-6 col-lg-2">
        <div class="stat-card d-flex align-items-center">
            <div class="stat-icon me-3"><i class="fas fa-users"></i></div>
            <div><div class="stat-number">{{ stats.total }}</div><small>Total</small></div>
        </div>
    </div>
    <div class="col-md-6 col-lg-2">
        <div class="stat-card d-flex align-items-center">
            <div class="stat-icon me-3"><i class="fas fa-crown"></i></div>
            <div><div class="stat-number">{{ stats.admins }}</div><small>Admins</small></div>
        </div>
    </div>
    <div class="col-md-6 col-lg-2">
        <div class="stat-card d-flex align-items-center">
            <div class="stat-icon me-3"><i class="fas fa-tractor"></i></div>
            <div><div class="stat-number">{{ stats.agriculteurs }}</div><small>Agriculteurs</small></div>
        </div>
    </div>
    <div class="col-md-6 col-lg-2">
        <div class="stat-card d-flex align-items-center">
            <div class="stat-icon me-3"><i class="fas fa-user"></i></div>
            <div><div class="stat-number">{{ stats.clients }}</div><small>Clients</small></div>
        </div>
    </div>
    <div class="col-md-6 col-lg-2">
        <div class="stat-card d-flex align-items-center">
