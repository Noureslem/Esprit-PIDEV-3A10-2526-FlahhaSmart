{# templates/admin/user_form.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}
{% block page_title %}{{ title }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                {{ form_start(form) }}
                
                <div class="row">
                    <div class="col-md-6">
                        {{ form_row(form.nom) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.prenom) }}
                    </div>
                </div>
                
                {{ form_row(form.email) }}
                
                <div class="row">
                    <div class="col-md-6">
                        {{ form_row(form.telephone) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.ville) }}
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        {{ form_row(form.role) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.actif) }}
                    </div>
                </div>
                
                {{ form_row(form.plainPassword) }}
                
                <div class="mt-3">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-circle"></i> Enregistrer
                    </button>
                    <a href="{{ path('admin_users') }}" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Retour
                    </a>
                </div>
                
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}