{% extends 'base.html.twig' %}

{% block title %}Notifications - FlahaSmart{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet">
<style>
    :root {
        --agri-green: #2e7d52;
        --agri-green-light: #4c9a6e;
        --agri-dark: #1a3c34;
        --bg-soft: #fefaf5;
    }
    body {
        background: var(--bg-soft);
    }
    .page-header {
        background: linear-gradient(135deg, #1a3c34 0%, #2d5a1e 100%);
        border-radius: 0 0 2rem 2rem;
        padding: 1.5rem 0;
        margin-bottom: 2rem;
        color: white;
        position: relative;
        overflow: hidden;
    }
    .page-header::after {
        content: "";
        position: absolute;
        width: 180px;
        height: 180px;
        border-radius: 50%;
        background: rgba(255,255,255,0.08);
        right: -30px;
        bottom: -50px;
    }
    .btn-back {
        background: rgba(255,255,255,0.2);
        border-radius: 2rem;
        padding: 0.5rem 1.2rem;
        color: white;
        text-decoration: none;
        transition: 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .btn-back:hover {
        background: rgba(255,255,255,0.35);
        color: white;
        transform: translateX(-3px);
    }
    .stat-card,
    .notification-list,
    .pagination-shell {
        background: white;
        border-radius: 1.5rem;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }
    .stat-card {
        padding: 1.2rem;
        transition: all 0.3s;
        border: 1px solid rgba(0,0,0,0.03);
    }
    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1);
    }
    .stat-icon {
        width: 50px;
        height: 50px;
        background: rgba(46,125,82,0.1);
        border-radius: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        color: var(--agri-green);
    }
    .stat-number {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--agri-dark);
        line-height: 1.2;
    }
    .notification-list,
    .pagination-shell {
        padding: 1.2rem;
    }
    .notification-item {
        border: 1px solid #e9ecef;
        border-radius: 0.5rem;
        padding: 1rem;
        margin-bottom: 1rem;
        transition: 0.2s;
    }
    .notification-item:hover {
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .notification-item.unread {
        border-left: 4px solid #ffc107;
        background: rgba(255,193,7,0.05);
    }
    .notification-type {
        font-size: 0.8rem;
        text-transform: uppercase;
        font-weight: bold;
        color: var(--agri-green);
    }
    .notification-date {
        font-size: 0.9rem;
        color: #6c757d;
    }
    .btn-close-notif {
        border-radius: 50px;
        padding: 0.25rem 0.75rem;
        font-size: 0.8rem;
    }
</style>
{% endblock %}

{% block body %}
<div class="page-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1 class="display-6 fw-bold mb-1"><i class="fas fa-bell me-3"></i>Notifications</h1>
                <p class="mb-0 opacity-75">Gérez toutes les notifications du système</p>
            </div>
            <div class="col-md-4 text-md-end">
                <a href="{{ path('dashboard_admin') }}" class="btn-back">
                    <i class="fas fa-arrow-left"></i>Retour au tableau de bord
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row g-4 mb-5" data-aos="fade-up">
        <div class="col-md-6 col-lg-3">
            <div class="stat-card d-flex align-items-center">
                <div class="stat-icon me-3"><i class="fas fa-bell"></i></div>
                <div><div class="stat-number">{{ pagination.total }}</div><small>Total</small></div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="stat-card d-flex align-items-center">
                <div class="stat-icon me-3"><i class="fas fa-envelope-open"></i></div>
                <div><div class="stat-number">{{ unreadCount }}</div><small>Non lues</small></div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="stat-card d-flex align-items-center">
                <div class="stat-icon me-3"><i class="fas fa-envelope"></i></div>
                <div><div class="stat-number">{{ pagination.total - unreadCount }}</div><small>Lues</small></div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="stat-card d-flex align-items-center">
                <div class="stat-icon me-3"><i class="fas fa-list"></i></div>
                <div><div class="stat-number">{{ pagination.pages }}</div><small>Pages</small></div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3" data-aos="fade-up" data-aos-delay="100">
        <div class="text-muted small"><i class="fas fa-bell me-1"></i>{{ pagination.total }} notification(s), page {{ pagination.page }}/{{ pagination.pages }}</div>
    </div>

    <div class="notification-list" data-aos="fade-up" data-aos-delay="150">
        {% for notification in notifications %}
            <div class="notification-item {{ not notification.lu ? 'unread' : '' }}">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="flex-grow-1">
                        <div class="notification-type mb-1">{{ notification.type }}</div>
                        <div class="notification-message mb-2">{{ notification.message }}</div>
                        <div class="notification-date">
                            <i class="far fa-calendar-alt me-1"></i>{{ notification.dateNotif|date('d/m/Y H:i') }}
                        </div>
                    </div>
             
                            </form>
                    
                    </div>
                </div>
            </div>
        {% else %}
            <div class="text-center py-5 text-muted">
                <i class="fas fa-bell-slash fa-3x mb-2"></i>
                <p class="mb-0">Aucune notification trouvée</p>
            </div>
        {% endfor %}
    </div>

    {% if pagination.pages > 1 %}
        <div class="pagination-shell mt-4">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
                <div class="small text-muted">
                    Affichage de {{ ((pagination.page - 1) * pagination.limit) + 1 }}
                    à {{ pagination.page * pagination.limit > pagination.total ? pagination.total : pagination.page * pagination.limit }}
                    sur {{ pagination.total }} notifications
                </div>
                <nav aria-label="Pagination des notifications">
                    <ul class="pagination mb-0">
                        <li class="page-item {{ pagination.page == 1 ? 'disabled' : '' }}">
                            <a class="page-link" href="{{ path('admin_notifications', {page: pagination.page - 1}) }}">Précédent</a>
                        </li>
                        {% for p in 1..pagination.pages %}
                            <li class="page-item {{ p == pagination.page ? 'active' : '' }}">
                                <a class="page-link" href="{{ path('admin_notifications', {page: p}) }}">{{ p }}</a>
                            </li>
                        {% endfor %}
                        <li class="page-item {{ pagination.page == pagination.pages ? 'disabled' : '' }}">
                            <a class="page-link" href="{{ path('admin_notifications', {page: pagination.page + 1}) }}">Suivant</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
<script>
    AOS.init({ duration: 600, once: true });
</script>
{% endblock %}