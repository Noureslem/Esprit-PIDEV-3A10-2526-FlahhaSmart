{% extends 'admin/base_admin.html.twig' %}

{% block title %}Gestion des Threads - Admin{% endblock %}

{% block admin_body %}
    <div class="panel-header">
        <div class="panel-title">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
            Gestion des Threads
        </div>
    </div>

    <div class="admin-table-container">
        <table class="admin-table">
            <thead>
            <tr>
                <th>ID</th>
                <th>Titre</th>
                <th>Auteur</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for thread in threads %}
                <tr>
                    <td>#{{ thread.idThread }}</td>
                    <td>{{ thread.titre }}</td>
                    <td>{{ thread.auteur ? thread.auteur.email : 'Inconnu' }}</td>
                    <td>{{ thread.dateCreation|ago }}</td>
                    <td>
                        <div style="display: flex; gap: 0.5rem;">
                            <!-- Bouton Édition -->
                            <a href="{{ path('forum_admin_thread_edit', {id: thread.idThread}) }}" class="btn" style="background: rgba(22, 163, 74, 0.1); color: var(--primary); padding: 0.25rem 0.5rem; border: 1px solid rgba(22, 163, 74, 0.2); font-size: 0.75rem; text-decoration: none;" title="Modifier le thread">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-right: 4px;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                Modifier
                            </a>
                            <!-- Bouton IA Traduction -->
                            <form method="post" action="{{ path('forum_admin_thread_translate', {id: thread.idThread}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('translate' ~ thread.idThread) }}">
                                <button type="submit" class="btn btn-primary" style="padding: 0.25rem 0.5rem; font-size: 0.75rem; background: #3b82f6;" title="Traduire en Anglais via IA">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-right: 4px;"><path d="M5 8l6 6"></path><path d="M4 14l6-6 2-3"></path><path d="M2 5h12"></path><path d="M7 2h1"></path><path d="M22 22l-5-10-5 10"></path><path d="M14 18h6"></path></svg>
                                    Traduire (EN)
                                </button>
                            </form>
                            <!-- Bouton Suppression -->
                            <form method="post" action="{{ path('forum_admin_thread_delete', {id: thread.idThread}) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer ce thread ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ thread.idThread) }}">
                                <button type="submit" class="btn btn-danger" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-right: 4px;"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6V20a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                    Supprimer
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" style="text-align:center; padding: 2rem; color: var(--text-muted);">Aucun thread trouvé.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="navigation" style="margin-top: 1.5rem; display: flex; justify-content: center;">
            {{ knp_pagination_render(threads) }}
        </div>
    </div>
{% endblock %}