{% extends 'base.html.twig' %}

{% block title %}Admin Equipements — FlahaSmart{% endblock %}
{% block page_title %}{{ 'nav.equipements'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .kpi-label { font-size: .7rem; text-transform: uppercase; letter-spacing: .08em; opacity: .75; }
        .kpi-value { font-size: 1.9rem; font-weight: 800; }
        .chart-wrap { height: 240px; }
        .usage-card { border: 1px solid #e2e8f0; border-radius: 14px; padding: 1rem; background: #fff; }
        .filter-card { background: #fff; border-radius: 14px; border: 1px solid #e2e8f0; }
    </style>
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <div>
        <h2 class="fw-bold mb-1">{{ 'nav.equipements'|trans }}</h2>
        <p class="text-muted small mb-0">Inventaire et disponibilite des equipements</p>
    </div>
    <div class="d-flex gap-2">
        <a href="{{ path('app_equipement_new') }}" class="btn btn-success">
            <i class="bi bi-plus-lg me-1"></i> Nouvel equipement
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-2">
        <div class="stat-card" style="--c1:#1a3c34;--c2:#2e7d52;">
            <div class="kpi-label">Total</div>
            <div class="kpi-value" data-count="{{ stats.total }}">0</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-2">
        <div class="stat-card" style="--c1:#1a6e35;--c2:#3aad74;">
            <div class="kpi-label">Disponibles</div>
            <div class="kpi-value" data-count="{{ stats.available }}">0</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card" style="--c1:#991b1b;--c2:#ef4444;">
            <div class="kpi-label">Indisponibles</div>
            <div class="kpi-value" data-count="{{ stats.unavailable }}">0</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card" style="--c1:#1a4fa0;--c2:#2196f3;">
            <div class="kpi-label">Taux dispo</div>
            <div class="kpi-value">{{ stats.availabilityRate }}%</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card p-3 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="mb-0 fw-bold">Repartition des etats</h6>
                <span class="badge bg-success-subtle text-success">Live</span>
            </div>
            <div class="chart-wrap">
                <canvas id="equipementStateChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card p-3 h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="mb-0 fw-bold">Types dominants</h6>
                <span class="text-muted small">{{ charts.types.labels|length }} types</span>
            </div>
            <div class="chart-wrap">
                <canvas id="equipementTypeChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="card p-3 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="mb-0 fw-bold">Equipements les plus utilises</h6>
        <span class="badge bg-secondary">Top {{ topUsed|length }}</span>
    </div>
    <div class="row g-3">
        {% for item in topUsed %}
            <div class="col-md-4">
                <div class="usage-card h-100">
                    <div class="fw-semibold">{{ item.nom }}</div>
                    <div class="text-muted small">{{ item.usageCount }} operations</div>
                </div>
            </div>
        {% else %}
            <p class="text-muted small mb-0">Aucune utilisation enregistree.</p>
        {% endfor %}
    </div>
</div>

<div class="filter-card p-3 mt-4">
    <form method="get" class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Recherche</label>
            <input type="text" name="q" class="form-control" value="{{ filters.q }}" placeholder="Nom, type, ID">
        </div>
        <div class="col-md-3">
            <label class="form-label">Type</label>
            <select name="type" class="form-select">
                <option value="">Tous</option>
                {% for t in types %}
                    <option value="{{ t }}" {% if filters.type == t %}selected{% endif %}>{{ t }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Etat</label>
            <select name="etat" class="form-select">
                <option value="">Tous</option>
                {% for e in etats %}
                    <option value="{{ e }}" {% if filters.etat == e %}selected{% endif %}>{{ e }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Limite</label>
            <select name="limit" class="form-select">
                {% for option in [10,20,50,100] %}
                    <option value="{{ option }}" {% if filters.limit == option %}selected{% endif %}>{{ option }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-search me-1"></i> Filtrer
            </button>
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <a href="{{ path('admin_equipements') }}" class="btn btn-outline-secondary w-100">
                <i class="bi bi-arrow-counterclockwise me-1"></i> Reinitialiser
            </a>
        </div>
    </form>
</div>

<div class="table-container mt-4">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>
                        Nom
                        <span class="sort-links">
                            <a href="{{ path('admin_equipements', filters|merge({'sort': 'nom', 'direction': 'ASC'})) }}" class="sort-link">▲</a>
                            <a href="{{ path('admin_equipements', filters|merge({'sort': 'nom', 'direction': 'DESC'})) }}" class="sort-link">▼</a>
                        </span>
                    </th>
                    <th>Type</th>
                    <th>Etat</th>
                    <th>Utilisation</th>
                </tr>
            </thead>
            <tbody>
            {% for equipement in equipements %}
                {% set usageCount = usageMap[equipement.id]|default(0) %}
                <tr>
                    <td class="text-muted">{{ equipement.id }}</td>
                    <td><strong>{{ equipement.nom }}</strong></td>
                    <td>{{ equipement.type }}</td>
                    <td>
                        <span class="badge badge-status-{{ equipement.etat|lower|replace({' ': '_', 'é': 'e'}) }}">
                            {{ equipement.etat }}
                        </span>
                    </td>
                    <td>{{ usageCount }} ops</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5">
                        <div class="empty-state">
                            <i class="bi bi-inbox d-block"></i>
                            <p class="mb-0">Aucun equipement trouve.</p>
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% if pagination.totalPages > 1 %}
<nav class="mt-3">
    <ul class="pagination justify-content-center">
        <li class="page-item {% if pagination.page == 1 %}disabled{% endif %}">
            <a class="page-link" href="{{ path('admin_equipements', filters|merge({'page': pagination.page - 1})) }}">Precedent</a>
        </li>
        {% for p in 1..pagination.totalPages %}
            <li class="page-item {% if p == pagination.page %}active{% endif %}">
                <a class="page-link" href="{{ path('admin_equipements', filters|merge({'page': p})) }}">{{ p }}</a>
            </li>
        {% endfor %}
        <li class="page-item {% if pagination.page == pagination.totalPages %}disabled{% endif %}">
            <a class="page-link" href="{{ path('admin_equipements', filters|merge({'page': pagination.page + 1})) }}">Suivant</a>
        </li>
    </ul>
</nav>
{% endif %}
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    document.querySelectorAll('[data-count]').forEach(el => {
        const target = parseInt(el.dataset.count, 10) || 0;
        let current = 0;
        const step = Math.ceil(target / 40) || 1;
        const timer = setInterval(() => {
            current = Math.min(current + step, target);
            el.textContent = current.toLocaleString('fr-FR');
            if (current >= target) clearInterval(timer);
        }, 30);
    });

    const stateData = {{ charts.states|json_encode|raw }};
    const typeData = {{ charts.types|json_encode|raw }};

    const stateEl = document.getElementById('equipementStateChart');
    if (stateEl && stateData.labels.length) {
        new Chart(stateEl, {
            type: 'doughnut',
            data: {
                labels: stateData.labels,
                datasets: [{
                    data: stateData.data,
                    backgroundColor: stateData.backgroundColor,
                    borderWidth: 2,
                    borderColor: '#ffffff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom' } }
            }
        });
    }

    const typeEl = document.getElementById('equipementTypeChart');
    if (typeEl && typeData.labels.length) {
        new Chart(typeEl, {
            type: 'bar',
            data: {
                labels: typeData.labels,
                datasets: [{
                    data: typeData.data,
                    backgroundColor: typeData.backgroundColor
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
            }
        });
    }
</script>
{% endblock %}
