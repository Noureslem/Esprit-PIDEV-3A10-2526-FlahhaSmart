<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}FlahaSmart Admin{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
    {% block stylesheets %}{% endblock %}
</head>
<body class="admin-body">

<aside class="admin-sidebar">
    <a href="{{ path('forum_admin_dashboard') }}" class="admin-logo">
        <span>🌱</span> FlahaSmart
    </a>

    <nav class="admin-nav">
        <a href="{{ path('forum_admin_dashboard') }}" class="admin-nav-item {% if app.request.attributes.get('_route') == 'forum_admin_dashboard' %}active{% endif %}">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
            Dashboard
        </a>
        <a href="{{ path('forum_admin_threads') }}" class="admin-nav-item {% if app.request.attributes.get('_route') == 'forum_admin_threads' %}active{% endif %}">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
            Threads
        </a>
        <a href="{{ path('forum_admin_commentaires') }}" class="admin-nav-item {% if app.request.attributes.get('_route') == 'forum_admin_commentaires' %}active{% endif %}">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
            Commentaires
        </a>
       
    </nav>

    <div style="margin-top: auto;">
        <a href="{{ path('thread_index') }}" class="admin-nav-item" style="color: var(--text-muted);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            Retour au Forum
        </a>
        <a href="{{ path('app_logout') }}" class="admin-nav-item" style="color: var(--danger); margin-top: 5px;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
            Déconnexion
        </a>
    </div>
</aside>

<main class="admin-main">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div style="margin-bottom: 1rem; padding: 1rem; border-radius: 0.5rem; background: {% if label == 'success' %}rgba(16,185,129,0.1); color: var(--success); border: 1px solid rgba(16,185,129,0.2);{% elseif label == 'error' %}rgba(239,68,68,0.1); color: var(--danger); border: 1px solid rgba(239,68,68,0.2);{% else %}rgba(59,130,246,0.1); color: var(--primary); border: 1px solid rgba(59,130,246,0.2);{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% block admin_body %}{% endblock %}
</main>

{% block javascripts %}{% endblock %}

</body>
</html>
