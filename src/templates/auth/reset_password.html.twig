{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe - FlahaSmart{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="{{ asset('css/auth.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="container auth-shell auth-shell-medium">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-6">
                <div class="card auth-card">
                    <div class="card-header auth-card-header text-center">
                        <div class="auth-back-wrap">
                            <a class="auth-back" href="{{ path('app_verify_reset_code') }}">
                                <i class="bi bi-arrow-left-circle"></i>Retour
                            </a>
                        </div>
                        <img src="{{ asset('logo.png') }}" alt="Logo" class="auth-logo">
                        <div class="auth-badge" aria-hidden="true">
                            <i class="bi bi-lock"></i>
                        </div>
                        <h3 class="auth-title mb-0">Nouveau mot de passe</h3>
                    </div>
                    <div class="card-body auth-card-body">
                        {% for message in app.flashes('success') %}
                            <div class="alert alert-success auth-alert">{{ message }}</div>
                        {% endfor %}

                        {% for message in app.flashes('error') %}
                            <div class="alert alert-danger auth-alert">{{ message }}</div>
                        {% endfor %}

                        <p class="text-muted text-center mb-4">
                            Choisissez un nouveau mot de passe securise pour votre compte.
                        </p>

                        <form method="post" action="{{ path('app_reset_password') }}" class="auth-form">
                            <div class="mb-3 auth-field">
                                <label for="password" class="form-label">Nouveau mot de passe</label>
                                <div class="input-icon">
                                    <i class="bi bi-shield-lock" aria-hidden="true"></i>
                                    <input type="password" class="form-control auth-input" id="password" name="password" required autofocus>
                                </div>
                                <small class="text-muted d-block mt-2">
                                    8 caracteres minimum, avec 1 majuscule, 1 minuscule et 1 chiffre.
                                </small>
                            </div>

                            <div class="mb-4 auth-field">
                                <label for="confirm_password" class="form-label">Confirmer le mot de passe</label>
                                <div class="input-icon">
                                    <i class="bi bi-check2-circle" aria-hidden="true"></i>
                                    <input type="password" class="form-control auth-input" id="confirm_password" name="confirm_password" required>
                                </div>
                            </div>

                            <button type="submit" class="btn auth-btn w-100">Modifier le mot de passe</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
