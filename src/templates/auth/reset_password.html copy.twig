<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Nouveau mot de passe - FlahaSmart</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background: linear-gradient(135deg, #2d5a1e, #4a8c2a); min-height: 100vh; }
        .card { border-radius: 20px; border: none; }
        .card-header { background: linear-gradient(135deg, #3d6b2e, #2c521e); border-radius: 20px 20px 0 0 !important; color: white; }
        .btn-primary { background: linear-gradient(135deg, #4a8c2a, #2d5a1e); border: none; border-radius: 50px; }
    </style>
</head>
<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card">
                    <div class="card-header text-center">
                        <i class="fas fa-lock fa-2x"></i>
                        <h3 class="mt-2">Nouveau mot de passe</h3>
                    </div>
                    <div class="card-body p-4">
                        {% for message in app.flashes('error') %}
                            <div class="alert alert-danger">{{ message }}</div>
                        {% endfor %}

                        <form method="post">
                            <div class="mb-3">
                                <label class="form-label">Nouveau mot de passe</label>
                                <input type="password" name="password" class="form-control" required>
                                <small class="text-muted">8 caractères min, 1 majuscule, 1 minuscule, 1 chiffre</small>
                            </div>
                            <div class="mb-4">
                                <label class="form-label">Confirmer le mot de passe</label>
                                <input type="password" name="confirm_password" class="form-control" required>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Modifier le mot de passe</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>