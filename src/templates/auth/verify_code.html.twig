{# templates/auth/verify_code.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Vérification du code - FlahaSmart{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    :root {
        --primary: #2d6a4f;
        --primary-dark: #1b4d3e;
        --primary-light: #40916c;
        --secondary: #ffb703;
        --gray-bg: #f8f9fc;
    }
    .verify-card {
        background: white;
        border-radius: 24px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        overflow: hidden;
        border: none;
        animation: fadeInUp 0.5s ease-out;
    }
    .verify-card .card-header {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        color: white;
        padding: 1.5rem;
        text-align: center;
        border-bottom: none;
    }
    .verify-card .card-body {
        padding: 2rem;
    }
    .form-control {
        border-radius: 50px;
        padding: 12px 20px;
        border: 1px solid #dee2e6;
        transition: all 0.2s;
        text-align: center;
        font-size: 1.2rem;
        letter-spacing: 4px;
    }
    .form-control:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(45,106,79,0.1);
    }
    .btn-verify {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        border: none;
        border-radius: 50px;
        padding: 12px;
        font-weight: 600;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-verify:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(45,106,79,0.3);
    }
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .code-hint {
        font-size: 0.85rem;
        color: #6c757d;
        text-align: center;
        margin-top: 1rem;
    }
    @media (max-width: 768px) {
        .verify-card .card-body {
            padding: 1.5rem;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="container mt-5 pt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="verify-card">
                <div class="card-header">
                    <i class="fas fa-envelope fs-1 mb-2 d-block"></i>
                    <h3 class="mb-0">Vérification du code</h3>
                    <p class="mb-0 opacity-75">Entrez le code reçu par email</p>
                </div>
                <div class="card-body">
                    {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                                <i class="fas fa-{{ label == 'success' ? 'check-circle' : 'exclamation-triangle' }} me-2"></i>
                                {{ message }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        {% endfor %}
                    {% endfor %}

                    <form method="post">
                        <div class="mb-4">
                            <label for="code" class="form-label fw-semibold">Code à 6 chiffres</label>
                            <input type="text" name="code" id="code" class="form-control text-center" 
                                   maxlength="6" pattern="[0-9]{6}" placeholder="000000" 
                                   autocomplete="off" required autofocus>
                        </div>
                        <button type="submit" class="btn btn-verify w-100 text-white">
                            <i class="fas fa-check-circle me-2"></i>Vérifier et finaliser
                        </button>
                    </form>

                    <div class="code-hint">
                        <i class="fas fa-info-circle"></i>
                        Vous n'avez pas reçu de code ? <a href="{{ path('app_resend_code') }}">Renvoyer</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    const codeInput = document.getElementById('code');
    codeInput.addEventListener('input', function(e) {
        this.value = this.value.replace(/[^0-9]/g, '').slice(0,6);
    });
</script>
{% endblock %}