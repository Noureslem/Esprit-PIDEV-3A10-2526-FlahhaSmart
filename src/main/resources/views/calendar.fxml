<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.commande.CalendarController"
      spacing="15"
      style="-fx-background-color: #f5f7fa; -fx-padding: 20;">

    <!-- En-tête -->
    <HBox alignment="CENTER_LEFT" spacing="15"
          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
        <Label text="🗓️ Calendrier des événements" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>
    </HBox>

    <!-- Barre de navigation mensuelle -->
    <HBox alignment="CENTER" spacing="20">
        <Button text="◀ Mois précédent" onAction="#previousMonth"
                style="-fx-background-color: #e0e0e0; -fx-background-radius: 8; -fx-padding: 8 16;"/>
        <Label fx:id="monthYearLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Button text="Mois suivant ▶" onAction="#nextMonth"
                style="-fx-background-color: #e0e0e0; -fx-background-radius: 8; -fx-padding: 8 16;"/>
    </HBox>

    <!-- Grille du calendrier -->
    <ScrollPane fitToWidth="true" style="-fx-background: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);">
        <GridPane fx:id="calendarGrid"
                  hgap="0" vgap="0"
                  gridLinesVisible="true"
                  style="-fx-background-color: white; -fx-padding: 5;">
        </GridPane>
    </ScrollPane>

</VBox>